{% comment %}
  Product Detail Page - Delivery Estimate Module (CANONICAL — Phase 3)
  
  This is the ONE AND ONLY delivery estimate component for PDP.
  Shows dynamic delivery range: "Pídelo hoy y recíbelo entre el {min} y el {max}"
  
  Rules:
  - Cut-off: 2:00 PM Colombia time (America/Bogota)
  - If order placed before 2pm → start counting from today
  - If order placed after 2pm → start counting from next calendar day
  - Business days = Mon-Fri (excludes Sat/Sun)
  - Delivery window: 2-5 business days
  - Locale: es-CO with long format (e.g. "jueves, 5 de marzo")
  
  Usage:
  {% render 'pdp-delivery-estimate' %}
  
  Note: Do NOT duplicate this component elsewhere on PDP.
{% endcomment %}

<div 
  class="ta-delivery-estimate"
  data-min-days="2"
  data-max-days="5"
  data-cutoff-hour="14"
  data-timezone="America/Bogota"
  data-locale="es-CO"
  aria-live="polite" 
  aria-atomic="true"
>
  <div class="ta-delivery-estimate__row">
    <span class="ta-delivery-estimate__icon" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 6h12v8H1V6z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
        <path d="M13 9h4l4 4v1h-8V9z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
        <circle cx="6" cy="16" r="2" stroke="currentColor" stroke-width="2"/>
        <circle cx="18" cy="16" r="2" stroke="currentColor" stroke-width="2"/>
        <path d="M8 16h8M1 16h3M20 16h3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </span>
    <span class="ta-delivery-estimate__text">
      {%- comment -%} 
        Fallback shown when JS hasn't loaded. JS replaces with dynamic dates.
      {%- endcomment -%}
      <span class="ta-delivery-estimate__date-range">Entrega estimada en 2-5 días hábiles</span>
    </span>
  </div>
</div>

<style>
  .ta-delivery-estimate {
    display: flex;
    align-items: center;
    background: var(--ta-bg-success, #F0FDF4);
    border: 1px solid var(--ta-border-success, #BBF7D0);
    border-radius: 0.5rem;
    padding: 0.6rem 1rem;
    margin: 0.8rem 0;
    color: var(--ta-success-dark, #15803D);
    font-size: 1.35rem;
    line-height: 1.5;
  }

  .ta-delivery-estimate__row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
  }

  .ta-delivery-estimate__icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    color: var(--ta-success, #16A34A);
  }

  .ta-delivery-estimate__text {
    flex: 1;
  }

  .ta-delivery-estimate__date-range strong {
    color: var(--ta-success-dark, #166534);
  }

  @media screen and (max-width: 749px) {
    .ta-delivery-estimate {
      font-size: 1.25rem;
      padding: 0.5rem 0.8rem;
    }
  }
</style>

{%- comment -%} 
  Load the JavaScript with defer for performance.
  Script includes guard against multiple initializations.
{%- endcomment -%}
<script src="{{ 'delivery-estimate.js' | asset_url }}" defer="defer"></script>
