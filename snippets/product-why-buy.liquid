{% comment %}
  Renders "Why buy from us" section
  
  Usage:
  {% render 'product-why-buy' %}
{% endcomment %}

<div class="product-why-buy">
  <h3 class="product-why-buy__title">¿Por qué comprar en TechAuraz?</h3>
  <div class="product-why-buy__grid">
    <div class="product-why-buy__item">
      <div class="product-why-buy__icon">{% render 'icon-system', icon: 'lock', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</div>
      <h4>Compra Segura</h4>
      <p>Tus datos están protegidos con encriptación SSL</p>
    </div>
    <div class="product-why-buy__item">
      <div class="product-why-buy__icon">{% render 'icon-system', icon: 'package', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</div>
      <h4>Productos Originales</h4>
      <p>100% productos de calidad garantizada</p>
    </div>
    <div class="product-why-buy__item">
      <div class="product-why-buy__icon">{% render 'icon-system', icon: 'headphones', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</div>
      <h4>Soporte 24/7</h4>
      <p>Atención por WhatsApp cuando lo necesites</p>
    </div>
    <div class="product-why-buy__item">
      <div class="product-why-buy__icon">{% render 'icon-system', icon: 'star', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</div>
      <h4>+500 Clientes Felices</h4>
      <p>Únete a nuestra comunidad de compradores satisfechos</p>
    </div>
  </div>
</div>
