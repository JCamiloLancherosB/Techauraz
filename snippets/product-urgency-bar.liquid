{%- comment -%}
  Renders an urgency/stock bar to encourage conversion.
{%- endcomment -%}
<div class="product-urgency-bar">
  <div class="urgency-element urgency-stock--low" style="background: rgba(254, 243, 199, 0.4); border-radius: 8px; border: 1px solid #FCD34D;">
    <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-fire" viewBox="0 0 24 24" style="width: 24px; height: 24px; color: #EA580C; fill: currentColor;">
      <path d="M12,22c4.97,0,9-4.03,9-9c0-4.97-4.03-9-9-9s-9,4.03-9,9C3,17.97,7.03,22,12,22z M12,2c5.52,0,10,4.48,10,10 c0,5.52-4.48,10-10,10S2,17.52,2,12C2,6.48,6.48,2,12,2z"></path>
      <path d="M12 9.5c-1.38 0-2.5 1.12-2.5 2.5s1.12 2.5 2.5 2.5 2.5-1.12 2.5-2.5-1.12-2.5-2.5-2.5zm0 3.5c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z"></path>
      <path d="M14.5 15.5l-2.5-1.5-2.5 1.5.5-2.8-2-2 2.8-.4 1.2-2.6 1.2 2.6 2.8.4-2 2 .5 2.8z"></path>
    </svg>
    <div style="font-size: 1.3rem; font-weight: 500; color: #9A3412; display: flex; flex-direction: column; width: 100%;">
      <span>🔥 <strong>¡Alta Demanda!</strong> Solo quedan <strong>3 unidades</strong>.</span>
      <div class="progress-bar" style="width: 100%; height: 6px; background: #FDE68A; border-radius: 4px; margin-top: 6px; overflow: hidden;">
        <div style="background: linear-gradient(90deg, #F59E0B, #EA580C); width: 85%; height: 100%; border-radius: 4px; animation: pulse-width 2s infinite alternate;"></div>
      </div>
    </div>
  </div>
</div>
<style>
@keyframes pulse-width {
  0% { width: 85%; }
  100% { width: 88%; }
}
</style>
