{%- comment -%}
  TechAuraz 2026 — Conversion Trust Strip
  - Shipping confirmation
  - Real stock availability (from variant inventory)
{%- endcomment -%}

<style>
  .ta-2026-booster { margin: 1.2rem 0; padding: 1rem 1.2rem; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: var(--radius-md, 8px); font-family: var(--font-body-family); }
  .ta-booster-shipping { display: flex; align-items: center; gap: 8px; font-size: 1.3rem; font-weight: 600; color: #166534; }
  .ta-blink-dot { width: 8px; height: 8px; border-radius: 50%; background-color: #22c55e; animation: ta-pulse 2s infinite; flex-shrink: 0; }
  @keyframes ta-pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }
  .ta-booster-stock { font-size: 1.15rem; color: #6b7280; margin-top: 6px; padding-top: 6px; border-top: 1px solid #dcfce7; }
  .ta-stock-low { color: #b45309; font-weight: 600; }
</style>

<div class="ta-2026-booster">
  <div class="ta-booster-shipping">
    <div class="ta-blink-dot"></div>
    <span>Envío gratis y pago contra entrega activos</span>
  </div>
  {%- assign current_variant = product.selected_or_first_available_variant -%}
  {%- if current_variant.inventory_management == 'shopify' and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= 10 -%}
    <div class="ta-booster-stock">
      📦 Quedan <strong class="ta-stock-low">{{ current_variant.inventory_quantity }} unidades</strong> disponibles
    </div>
  {%- endif -%}
</div>