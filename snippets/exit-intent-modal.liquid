{%- comment -%}
  EXIT-INTENT RESCUE MODAL — Phase 3 Revenue Protocol
  ====================================================
  Behavioral last-chance modal. Fires ONCE per 48h via localStorage.
  
  Detection:
  - Desktop: Mouse crosses top viewport boundary (clientY < 15)
  - Mobile: Rapid upward scroll velocity OR 60s idle timeout
  
  Usage (PDP only):
  {% render 'exit-intent-modal' %}
{%- endcomment -%}

{%- comment -%} ── Modal HTML ──────────────────────────────────────── {%- endcomment -%}
<div class="ei-modal" id="ExitIntentModal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="EI-Headline">
  <div class="ei-modal__backdrop" id="EI-Backdrop"></div>
  <div class="ei-modal__card">
    <button class="ei-modal__close" id="EI-Close" type="button" aria-label="Cerrar">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>

    <div class="ei-modal__emoji">🛑</div>
    <h2 class="ei-modal__headline" id="EI-Headline">¡ESPERA! ¿Te vas sin tu regalo?</h2>
    <p class="ei-modal__body">
      Nos sobran <strong>3 cupones de ENVÍO GRATIS</strong> por hoy. Termina tu compra ahora y nosotros cubrimos el <strong>100% del flete</strong> a cualquier ciudad de Colombia.
    </p>

    <button class="ei-modal__cta" id="EI-Accept" type="button">
      🟢 ACTIVAR ENVÍO GRATIS Y COMPRAR
    </button>

    <button class="ei-modal__dismiss" id="EI-Dismiss" type="button">
      No gracias, prefiero pagar el costo de envío regular.
    </button>
  </div>
</div>

{%- comment -%} ── Styles ─────────────────────────────────────────── {%- endcomment -%}
<style>
  /* ── Backdrop ──────────────────────────────────────── */
  .ei-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    pointer-events: none;
  }

  .ei-modal[aria-hidden="false"] {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .ei-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* ── Card ───────────────────────────────────────────── */
  .ei-modal__card {
    position: relative;
    background: var(--ta-surface, #fff);
    border-radius: 1.2rem;
    padding: 2.5rem 2rem 2rem;
    max-width: 440px;
    width: 100%;
    text-align: center;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.3);
    transform: scale(0.9) translateY(20px);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .ei-modal[aria-hidden="false"] .ei-modal__card {
    transform: scale(1) translateY(0);
  }

  .ei-modal__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    color: var(--ta-text-disabled, #94a3b8);
    cursor: pointer;
    padding: 0.3rem;
    border-radius: 0.3rem;
    transition: color 0.2s, background 0.2s;
  }

  .ei-modal__close:hover {
    color: var(--ta-text-primary, #1e293b);
    background: var(--ta-bg-secondary, #f1f5f9);
  }

  /* ── Content ────────────────────────────────────────── */
  .ei-modal__emoji {
    font-size: 3.5rem;
    margin-bottom: 0.5rem;
    line-height: 1;
  }

  .ei-modal__headline {
    font-size: 2rem;
    font-weight: 800;
    color: var(--ta-text-primary, #0f172a);
    margin: 0 0 0.8rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .ei-modal__body {
    font-size: 1.4rem;
    color: var(--ta-text-secondary, #475569);
    line-height: 1.6;
    margin: 0 0 1.5rem;
  }

  .ei-modal__body strong {
    color: var(--ta-text-primary, #0f172a);
  }

  /* ── Primary CTA (pulsing green) ────────────────────── */
  .ei-modal__cta {
    display: block;
    width: 100%;
    background: linear-gradient(135deg, #22c55e, #16a34a);
    color: var(--ta-text-inverse, #fff);
    border: none;
    border-radius: 0.7rem;
    padding: 1rem 1.5rem;
    font-size: 1.5rem;
    font-weight: 800;
    cursor: pointer;
    letter-spacing: 0.01em;
    transition: transform 0.2s, box-shadow 0.2s;
    animation: ei-pulse 2s ease-in-out infinite;
  }

  .ei-modal__cta:hover {
    transform: scale(1.03);
    box-shadow: 0 6px 20px rgba(34, 197, 94, 0.5);
  }

  .ei-modal__cta:active {
    transform: scale(0.98);
  }

  @keyframes ei-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5); }
    50% { box-shadow: 0 0 0 10px rgba(34, 197, 94, 0); }
  }

  /* ── Dismiss Link ───────────────────────────────────── */
  .ei-modal__dismiss {
    display: block;
    width: 100%;
    background: none;
    border: none;
    color: var(--ta-text-disabled, #94a3b8);
    font-size: 1.2rem;
    cursor: pointer;
    margin-top: 1rem;
    padding: 0.5rem;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .ei-modal__dismiss:hover {
    color: var(--ta-text-muted, #64748b);
  }

  /* ── Mobile ─────────────────────────────────────────── */
  @media screen and (max-width: 749px) {
    .ei-modal {
      padding: 1rem;
      align-items: flex-end;
    }

    .ei-modal__card {
      padding: 2rem 1.5rem 1.5rem;
      border-radius: 1.2rem 1.2rem 0 0;
      max-width: 100%;
    }

    .ei-modal__headline {
      font-size: 1.7rem;
    }

    .ei-modal__body {
      font-size: 1.3rem;
    }

    .ei-modal__cta {
      font-size: 1.35rem;
      padding: 0.9rem 1rem;
    }
  }
</style>

{%- comment -%} ── Detection Engine + Modal Logic ─────────────────── {%- endcomment -%}
<script>
  /* ═══════════════════════════════════════════════════════════
     EXIT-INTENT RESCUE ENGINE — Phase 3
     Desktop: mouseout top boundary · Mobile: scroll velocity + idle
     48h localStorage cooldown · Fires once per session max
     ═══════════════════════════════════════════════════════════ */
  (function() {
    'use strict';

    /* ── Config ─────────────────────────────────────── */
    var COOLDOWN_KEY    = 'ta_ei_modal_shown';
    var COOLDOWN_MS     = 48 * 60 * 60 * 1000; /* 48 hours */
    var MOUSE_THRESHOLD = 15;    /* px from top */
    var IDLE_TIMEOUT_MS = 60000; /* 60s idle on mobile */
    var SCROLL_VELOCITY = -80;   /* px/100ms upward (negative = up) */
    var ARM_DELAY_MS    = 5000;  /* Don't fire in first 5s */

    /* ── State ──────────────────────────────────────── */
    var modal     = document.getElementById('ExitIntentModal');
    var backdrop  = document.getElementById('EI-Backdrop');
    var closeBtn  = document.getElementById('EI-Close');
    var acceptBtn = document.getElementById('EI-Accept');
    var dismissBtn = document.getElementById('EI-Dismiss');
    if (!modal) return;

    var fired   = false;
    var armed   = false;
    var idleTimer = null;

    /* ── Cooldown Check ─────────────────────────────── */
    function isOnCooldown() {
      try {
        var ts = localStorage.getItem(COOLDOWN_KEY);
        if (!ts) return false;
        return (Date.now() - parseInt(ts, 10)) < COOLDOWN_MS;
      } catch (e) { return false; }
    }

    function setCooldown() {
      try { localStorage.setItem(COOLDOWN_KEY, Date.now()); } catch (e) {}
    }

    if (isOnCooldown()) return;

    /* ── Arm after delay ────────────────────────────── */
    setTimeout(function() { armed = true; }, ARM_DELAY_MS);

    /* ── Show / Hide ────────────────────────────────── */
    function showModal() {
      if (fired || !armed) return;
      fired = true;
      setCooldown();
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function hideModal() {
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    /* ── Close handlers ─────────────────────────────── */
    closeBtn.addEventListener('click', hideModal);
    dismissBtn.addEventListener('click', hideModal);
    backdrop.addEventListener('click', hideModal);

    /* ── Accept: close + scroll to buy button ─────── */
    acceptBtn.addEventListener('click', function() {
      hideModal();
      /* Scroll to the primary Add-to-Cart / Buy button */
      var buyBtn = document.querySelector('.product-form__submit')
                || document.querySelector('[name="add"]')
                || document.querySelector('.shopify-payment-button');
      if (buyBtn) {
        buyBtn.scrollIntoView({ behavior: 'smooth', block: 'center' });
        /* Brief highlight */
        buyBtn.style.transition = 'box-shadow 0.3s ease';
        buyBtn.style.boxShadow = '0 0 0 4px rgba(34, 197, 94, 0.5)';
        setTimeout(function() { buyBtn.style.boxShadow = ''; }, 2000);
      }
    });

    /* Escape key */
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') {
        hideModal();
      }
    });

    /* ═══════════════════════════════════════════════════
       DETECTION: Desktop — Mouse exits top of viewport
       ═══════════════════════════════════════════════════ */
    var isMobile = window.matchMedia('(max-width: 767px)').matches
                || ('ontouchstart' in window);

    if (!isMobile) {
      document.addEventListener('mouseout', function(e) {
        if (e.clientY < MOUSE_THRESHOLD && e.relatedTarget === null) {
          showModal();
        }
      });
    }

    /* ═══════════════════════════════════════════════════
       DETECTION: Mobile — Scroll velocity + Idle timeout
       ═══════════════════════════════════════════════════ */
    if (isMobile) {
      /* ── Scroll Velocity ─────────────────────────── */
      var lastScrollY = window.scrollY;
      var lastScrollT = Date.now();

      window.addEventListener('scroll', function() {
        var now = Date.now();
        var dt  = now - lastScrollT;
        if (dt < 50) return; /* throttle */

        var dy = window.scrollY - lastScrollY;
        var velocity = (dy / dt) * 100; /* px per 100ms */

        if (velocity < SCROLL_VELOCITY && window.scrollY > 200) {
          showModal();
        }

        lastScrollY = window.scrollY;
        lastScrollT = now;
      }, { passive: true });

      /* ── Idle Timeout ────────────────────────────── */
      function resetIdle() {
        clearTimeout(idleTimer);
        idleTimer = setTimeout(showModal, IDLE_TIMEOUT_MS);
      }

      ['touchstart', 'scroll'].forEach(function(evt) {
        window.addEventListener(evt, resetIdle, { passive: true });
      });
      resetIdle();
    }
  })();
</script>
