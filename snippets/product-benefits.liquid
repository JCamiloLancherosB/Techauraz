{% comment %}
  Renders product benefits section with icons
  
  Usage:
  {% render 'product-benefits' %}
{% endcomment %}

<div class="product-benefits">
  <h3 class="product-benefits__title">Beneficios Principales</h3>
  <ul class="product-benefits__list">
    <li class="product-benefits__item">
      <span class="product-benefits__icon">{% render 'icon-system', icon: 'shipping', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</span>
      <div class="product-benefits__content">
        <strong>Envío Gratis</strong>
        <span>A toda Colombia sin costo adicional</span>
      </div>
    </li>
    <li class="product-benefits__item">
      <span class="product-benefits__icon">{% render 'icon-system', icon: 'payment', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</span>
      <div class="product-benefits__content">
        <strong>Pago Contra Entrega</strong>
        <span>Paga cuando recibas tu pedido</span>
      </div>
    </li>
    <li class="product-benefits__item">
      <span class="product-benefits__icon">{% render 'icon-system', icon: 'guarantee', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</span>
      <div class="product-benefits__content">
        <strong>Garantía 30 Días</strong>
        <span>Devolución sin preguntas</span>
      </div>
    </li>
    <li class="product-benefits__item">
      <span class="product-benefits__icon">{% render 'icon-system', icon: 'lightning', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</span>
      <div class="product-benefits__content">
        <strong>Entrega Rápida</strong>
        <span>2-4 días hábiles</span>
      </div>
    </li>
  </ul>
</div>
