{%- comment -%}
  TechAuraz Unified SVG Icon System
  ================================
  Replaces all emojis with consistent, scalable SVG icons.
  Usage: {% render 'icon-system', icon: 'shipping' %}
  Optional: {% render 'icon-system', icon: 'shipping', size: 32, color: 'var(--tech-accent)' %}
{%- endcomment -%}

{%- liquid
  assign icon_size = size | default: 24
  assign icon_color = color | default: 'currentColor'
  assign icon_class = class | default: ''
-%}

{%- case icon -%}

  {%- when 'shipping' -%}
    {%- comment -%} Replaces 🚚 — Free shipping / delivery truck {%- endcomment -%}
    <svg class="icon-system {{ icon_class }}" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="{{ icon_color }}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M16 16V3H1v13"/>
      <path d="M16 8h4l3 3v5h-7"/>
      <circle cx="5.5" cy="18.5" r="2.5"/>
      <circle cx="18.5" cy="18.5" r="2.5"/>
    </svg>

  {%- when 'payment' -%}
    {%- comment -%} Replaces 💳 — Payment / credit card {%- endcomment -%}
    <svg class="icon-system {{ icon_class }}" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="{{ icon_color }}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
      <line x1="1" y1="10" x2="23" y2="10"/>
      <line x1="5" y1="15" x2="9" y2="15"/>
    </svg>

