{% comment %}
  LocalBusiness Structured Data (JSON-LD)
  Complements Organization schema with local business details for Google Maps/Local SEO
  Usage: {% render 'schema-local-business' %}
{% endcomment %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Store",
  "name": {{ shop.name | json }},
  "alternateName": "TechAuraz Colombia",
  "url": {{ shop.url | json }},
  "description": "Tienda líder en Colombia de tecnología premium: audífonos gamer, smartwatches, memorias USB personalizadas y accesorios tech. Envío gratis a toda Colombia con pago contra entrega.",
  {% if settings.logo %}
  "logo": {{ settings.logo | image_url: width: 500 | prepend: 'https:' | json }},
  "image": {{ settings.logo | image_url: width: 500 | prepend: 'https:' | json }},
  {% endif %}
  "telephone": "+57-300-860-2789",
  "email": "soporte@techauraz.com",
  "priceRange": "$$ - $$$",
  "currenciesAccepted": "COP",
  "paymentAccepted": "Efectivo, Tarjeta de Crédito, Tarjeta de Débito, PSE, Efecty, Nequi, Daviplata, Contraentrega",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:00",
      "closes": "18:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "09:00",
      "closes": "14:00"
    }
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Carrera 7",
    "addressLocality": "Bogotá",
    "addressRegion": "Cundinamarca",
    "postalCode": "110111",
    "addressCountry": "CO"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "4.570868",
    "longitude": "-74.297333"
  },
  "areaServed": {
    "@type": "Country",
    "name": "Colombia"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Productos TechAuraz",
    "itemListElement": [
      {
        "@type": "OfferCatalog",
        "name": "Audífonos y Diademas Gamer",
        "itemListElement": []
      },
      {
        "@type": "OfferCatalog",
        "name": "Smart Watches y Electrónicos",
        "itemListElement": []
      },
      {
        "@type": "OfferCatalog",
        "name": "Memorias USB Personalizadas",
        "itemListElement": []
      },
      {
        "@type": "OfferCatalog",
        "name": "Accesorios Tecnológicos",
        "itemListElement": []
      },
      {
        "@type": "OfferCatalog",
        "name": "Iluminación LED",
        "itemListElement": []
      }
    ]
  },
  {%- comment -%}
    AggregateRating RE-ENABLED (2026-04-04):
    Now reads from Judge.me metafields (verified review app).
    Previously hardcoded "4.9 / 527" — that was fabricated and removed.
    Guard clause: only emits when real reviews exist (count > 0).
  {%- endcomment -%}
  {%- assign jm_count = shop.metafields.judgeme.all_reviews_count | plus: 0 -%}
  {%- assign jm_rating = shop.metafields.judgeme.all_reviews_rating -%}
  {%- if jm_count > 0 and jm_rating != blank -%}
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "{{ jm_rating }}",
    "reviewCount": "{{ jm_count }}",
    "bestRating": "5",
    "worstRating": "1"
  },
  {%- endif -%}
  "slogan": "Tecnología Premium con Envío GRATIS a Todo Colombia",
  "foundingDate": "2024",
  "knowsAbout": [
    "Audífonos inalámbricos",
    "Smartwatch",
    "Memorias USB personalizadas",
    "Accesorios tecnológicos",
    "Gadgets electrónicos",
    "Iluminación LED",
    "Cargadores rápidos",
    "Hubs USB"
  ],
  "makesOffer": {
    "@type": "Offer",
    "description": "Envío GRATIS a toda Colombia + Pago contra entrega + Garantía 30 días",
    "availableDeliveryMethod": "http://purl.org/goodrelations/v1#DeliveryModeParcelService"
  }
}
</script>
