{%- comment -%}
  Trust Line Strip - Reusable snippet for PDP trust badges
  Shows: Envío gratis, Contraentrega, Garantía 30 días, Devolución fácil
  
  Usage: {% render 'trust-line', block: block %}
{%- endcomment -%}
<div class="tech-trust-line" {{ block.shopify_attributes }} role="list" aria-label="Beneficios de compra">
  <div class="tech-trust-line__item" role="listitem">
    <span class="tech-trust-line__icon" aria-hidden="true">{% render 'icon-system', icon: 'shipping', size: 16, color: 'var(--ta-accent, #00D4AA)' %}</span>
    <span class="tech-trust-line__text">{{ block.settings.text_shipping | default: "Envío gratis" }}</span>
  </div>
  <div class="tech-trust-line__item" role="listitem">
    <span class="tech-trust-line__icon" aria-hidden="true">{% render 'icon-system', icon: 'payment', size: 16, color: 'var(--ta-accent, #00D4AA)' %}</span>
    <span class="tech-trust-line__text">{{ block.settings.text_1 | default: "Contraentrega en Colombia" }}</span>
  </div>
  <div class="tech-trust-line__item" role="listitem">
    <span class="tech-trust-line__icon" aria-hidden="true">{% render 'icon-system', icon: 'check-circle', size: 16, color: 'var(--ta-accent, #00D4AA)' %}</span>
    <span class="tech-trust-line__text">{{ block.settings.text_2 | default: "Garantía 30 días" }}</span>
  </div>
  <div class="tech-trust-line__item" role="listitem">
    <span class="tech-trust-line__icon" aria-hidden="true">{% render 'icon-system', icon: 'refresh-ccw', size: 16, color: 'var(--ta-accent, #00D4AA)' %}</span>
    <span class="tech-trust-line__text">{{ block.settings.text_return | default: "Devolución fácil" }}</span>
  </div>
</div>
