{%- comment -%}TechAuraz 2026 Micro-Animations{%- endcomment -%}
<style>
  /* Add to Cart Click Haptic Feedback */
  .button, .product-form__submit, .ta-sticky-btn {
    transition: transform 0.1s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.1s cubic-bezier(0.4, 0, 0.2, 1) !important;
  }
  .button:active, .product-form__submit:active, .ta-sticky-btn:active {
    transform: scale(0.96) !important;
    box-shadow: inset 0 2px 4px rgba(0,0,0,0.2) !important;
  }

  /* Cart Count Pop Animation */
  .cart-count-bubble {
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .cart-count-bubble.pop-animation {
    transform: scale(1.4);
  }

  /* Smooth reveal for product cards on scroll */
  .card-wrapper {
    opacity: 0;
    transform: translateY(15px);
    animation: fadeUpReveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeUpReveal {
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Listen for cart additions to pop the bubble
    document.addEventListener('submit', (e) => {
      if (e.target.action && e.target.action.includes('/cart/add')) {
        const bubble = document.querySelector('.cart-count-bubble');
        if (bubble) {
          setTimeout(() => {
             bubble.classList.add('pop-animation');
             setTimeout(() => bubble.classList.remove('pop-animation'), 400);
          }, 300);
        }
      }
    });
  });
</script>
