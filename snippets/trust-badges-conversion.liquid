{% comment %}
  Conversion Trust Badges Section
  
  Displays prominent trust badges for conversion optimization:
  - Free shipping
  - Cash on delivery
  - Guarantee
  - Fast delivery
  
  Usage:
  {% render 'trust-badges-conversion' %}
{% endcomment %}

<div class="ta-conv-trust-section">
  <div class="ta-conv-trust-badge">
    <div class="ta-conv-trust-badge__icon">{% render 'icon-system', icon: 'shipping', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</div>
    <h3 class="ta-conv-trust-badge__title">Envío GRATIS</h3>
    <p class="ta-conv-trust-badge__text">A toda Colombia</p>
  </div>
  
  <div class="ta-conv-trust-badge">
    <div class="ta-conv-trust-badge__icon">{% render 'icon-system', icon: 'payment', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</div>
    <h3 class="ta-conv-trust-badge__title">Pago contra entrega</h3>
    <p class="ta-conv-trust-badge__text">Sin riesgos</p>
  </div>
  
  <div class="ta-conv-trust-badge">
    <div class="ta-conv-trust-badge__icon">{% render 'icon-system', icon: 'guarantee', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</div>
    <h3 class="ta-conv-trust-badge__title">Garantía 30 días</h3>
    <p class="ta-conv-trust-badge__text">Devolución fácil</p>
  </div>
  
  <div class="ta-conv-trust-badge">
    <div class="ta-conv-trust-badge__icon">{% render 'icon-system', icon: 'lightning', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</div>
    <h3 class="ta-conv-trust-badge__title">Entrega rápida</h3>
    <p class="ta-conv-trust-badge__text">2-5 días</p>
  </div>
</div>
