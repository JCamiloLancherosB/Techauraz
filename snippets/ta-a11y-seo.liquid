{%- comment -%}TechAuraz 2026 A11y & SEO Script{%- endcomment -%}
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. 2026 Accessibility automated ARIA injection
    document.querySelectorAll('button:not([aria-label]), a.button:not([aria-label])').forEach(el => {
      const text = el.innerText.trim();
      if (text) { el.setAttribute('aria-label', text); }
      else { el.setAttribute('aria-label', 'Botón interactivo'); }
    });
    
    // 2. Add structural focus rings for keyboard nav
    const style = document.createElement('style');
    style.innerHTML = ":focus-visible { outline: 2px solid var(--color-base-accent-1, #E52E2D) !important; outline-offset: 3px !important; }";
    document.head.appendChild(style);

    // 3. Dynamic Schema.org injection for Product Pages
    {% if template.name == 'product' %}
      if (!document.querySelector('script[type="application/ld+json"]')) {
        const schema = {
          "@context": "https://schema.org/",
          "@type": "Product",
          "name": "{{ product.title | escape }}",
          "image": [
            {%- for image in product.images limit:3 -%}
              "https:{{ image.src | image_url }}"{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          ],
          "description": "{{ product.description | strip_html | truncatewords: 30 | escape }}",
          "sku": "{{ product.variants.first.sku }}",
          "brand": {
            "@type": "Brand",
            "name": "TechAuraZ"
          },
          "offers": {
            "@type": "Offer",
            "url": "{{ shop.url }}{{ product.url }}",
            "priceCurrency": "{{ cart.currency.iso_code }}",
            "price": "{{ product.price | money_without_currency | remove: ',' | remove: '.' }}",
            "itemCondition": "https://schema.org/NewCondition",
            "availability": "https://schema.org/InStock",
            "seller": { "@type": "Organization", "name": "TechAuraZ" }
          }
        };
        const script = document.createElement('script');
        script.type = 'application/ld+json';
        script.textContent = JSON.stringify(schema);
        document.head.appendChild(script);
      }
    {% endif %}
  });
</script>
