{%- comment -%}
  Smart Cart Upsell — TechAuraz 2026
  
  Hidden CRO tip: Cart drawer upsell recommendations increase AOV by 15-25%.
  Shows contextually relevant products based on what's in the cart.
  
  Strategy:
  - If cart has audio products → suggest cables/cases
  - If cart has phone accessories → suggest power banks
  - Default: show best sellers
  
  Usage: {% render 'cart-upsell' %}
  Place inside cart-drawer.liquid after the items list.
{%- endcomment -%}

{%- if cart.item_count > 0 -%}
  {%- comment -%} Determine cart category for smart recommendations {%- endcomment -%}
  {%- assign has_audio = false -%}
  {%- assign has_charging = false -%}
  {%- assign has_gaming = false -%}
  {%- assign cart_product_ids = '' -%}
  
  {%- for item in cart.items -%}
    {%- assign cart_product_ids = cart_product_ids | append: item.product.id | append: ',' -%}
    {%- assign item_tags = item.product.tags | downcase -%}
    {%- if item_tags contains 'audio' or item_tags contains 'parlante' or item_tags contains 'audifono' -%}
      {%- assign has_audio = true -%}
    {%- endif -%}
    {%- if item_tags contains 'carga' or item_tags contains 'cable' or item_tags contains 'powerbank' -%}
      {%- assign has_charging = true -%}
    {%- endif -%}
    {%- if item_tags contains 'gaming' or item_tags contains 'gamer' -%}
      {%- assign has_gaming = true -%}
    {%- endif -%}
  {%- endfor -%}

  {%- comment -%} Select recommendation collection based on cart content {%- endcomment -%}
  {%- if has_audio -%}
    {%- assign upsell_collection = collections['cables-carga'] -%}
    {%- assign upsell_title = 'Complementa tu Audio' -%}
  {%- elsif has_charging -%}
    {%- assign upsell_collection = collections['audio'] -%}
    {%- assign upsell_title = 'Mejora tu Experiencia' -%}
  {%- elsif has_gaming -%}
    {%- assign upsell_collection = collections['gaming-pc'] -%}
    {%- assign upsell_title = 'Completa tu Setup' -%}
  {%- else -%}
    {%- assign upsell_collection = collections['accesorios-para-celular'] -%}
    {%- assign upsell_title = 'También te puede gustar' -%}
  {%- endif -%}

  {%- if upsell_collection and upsell_collection.products.size > 0 -%}
    <div class="cart-upsell" id="cart-upsell-section" role="complementary" aria-label="Productos recomendados">
      <div class="cart-upsell__header">
        <span class="cart-upsell__icon" aria-hidden="true">💡</span>
        <h3 class="cart-upsell__title">{{ upsell_title }}</h3>
      </div>
      <div class="cart-upsell__grid">
        {%- assign shown = 0 -%}
        {%- for product in upsell_collection.products limit: 6 -%}
          {%- unless cart_product_ids contains product.id -%}
            {%- if shown < 3 -%}
              <a href="{{ product.url }}" class="cart-upsell__item" data-upsell-product="{{ product.id }}">
                {%- if product.featured_image -%}
                  <img 
                    src="{{ product.featured_image | image_url: width: 100, height: 100, crop: 'center' }}" 
                    alt="{{ product.title | escape }}"
                    width="100" height="100"
                    loading="lazy"
                    class="cart-upsell__image">
                {%- endif -%}
                <div class="cart-upsell__info">
                  <p class="cart-upsell__name">{{ product.title | truncate: 35 }}</p>
                  <div class="cart-upsell__price">
                    {%- if product.compare_at_price > product.price -%}
                      <span class="cart-upsell__price-compare">{{ product.compare_at_price | money_without_trailing_zeros }}</span>
                    {%- endif -%}
                    <span class="cart-upsell__price-current">{{ product.price | money_without_trailing_zeros }}</span>
                  </div>
                </div>
              </a>
              {%- assign shown = shown | plus: 1 -%}
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
{%- endif -%}

<style>
  .cart-upsell {
    padding: 16px;
    margin: 12px 0 0;
    border-top: 1px solid var(--color-border, #e2e8f0);
  }
  .cart-upsell__header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }
  .cart-upsell__icon { font-size: 18px; }
  .cart-upsell__title {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text-primary, #0f172a);
    margin: 0;
  }
  .cart-upsell__grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .cart-upsell__item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px;
    border-radius: 10px;
    border: 1px solid var(--color-border, #e2e8f0);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .cart-upsell__item:hover {
    border-color: var(--color-primary, #2563eb);
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.1);
  }
  .cart-upsell__image {
    width: 56px;
    height: 56px;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
  }
  .cart-upsell__info { flex: 1; min-width: 0; }
  .cart-upsell__name {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-primary, #0f172a);
    margin: 0 0 4px;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .cart-upsell__price {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .cart-upsell__price-compare {
    font-size: 12px;
    color: var(--color-text-muted, #94a3b8);
    text-decoration: line-through;
  }
  .cart-upsell__price-current {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-primary, #2563eb);
  }
</style>

<script>
// Track upsell clicks in GTM
document.querySelectorAll('[data-upsell-product]').forEach(function(el) {
  el.addEventListener('click', function() {
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'select_promotion',
      promotion_name: 'cart_upsell',
      creative_name: this.querySelector('.cart-upsell__name').textContent.trim(),
      promotion_id: this.dataset.upsellProduct
    });
  });
});
</script>
