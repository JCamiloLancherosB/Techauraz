{% comment %}
    Renders product media — Phase 3 Performance Optimized
    
    Uses <picture> with AVIF/WebP sources and JPG fallback.
    Hero image (first slide) gets fetchpriority="high" + decoding="sync".
    Subsequent images get loading="lazy" + decoding="async".

    Accepts:
    - media: {Object} Product Media object
    - loop: {Boolean} Enable video looping (optional)
    - variant_image: {Boolean} Whether or not media is associated with a variant
    - is_hero: {Boolean} True for LCP-critical first image (fetchpriority="high")

    Usage:
    {% render 'product-media',
      media: media,
      loop: section.settings.enable_video_looping,
      variant_image: true,
      is_hero: forloop.first
    %}
{% endcomment %}

{%- if media.media_type == 'image' -%}
  {%- comment -%}
    PICTURE ELEMENT: Modern image architecture
    - <source type="image/avif"> → Smallest, best compression (Chrome 85+, FF 93+)
    - <source type="image/webp"> → Wide support fallback (Chrome 32+, FF 65+, Safari 14+)
    - <img> → Universal JPG fallback
    
    Shopify CDN auto-serves AVIF/WebP via the format parameter.
    Sizes: 550w (mobile), 1100w (tablet), 1445w (desktop), up to 2200w (retina)
  {%- endcomment -%}

  {%- liquid
    assign img_alt = media.alt | default: media.preview_image.alt | escape
    assign img_width = 1100
    assign img_height = 1100 | divided_by: media.preview_image.aspect_ratio | ceil
  -%}

  <picture>
    {%- comment -%} AVIF source — best compression, smallest file size {%- endcomment -%}
    <source
      type="image/avif"
      srcset="{%- if media.preview_image.width >= 550 -%}{{ media.preview_image | image_url: width: 550, format: 'avif' }} 550w,{%- endif -%}
              {%- if media.preview_image.width >= 1100 -%}{{ media.preview_image | image_url: width: 1100, format: 'avif' }} 1100w,{%- endif -%}
              {%- if media.preview_image.width >= 1445 -%}{{ media.preview_image | image_url: width: 1445, format: 'avif' }} 1445w,{%- endif -%}
              {%- if media.preview_image.width >= 1680 -%}{{ media.preview_image | image_url: width: 1680, format: 'avif' }} 1680w,{%- endif -%}
              {%- if media.preview_image.width >= 2200 -%}{{ media.preview_image | image_url: width: 2200, format: 'avif' }} 2200w,{%- endif -%}
              {{ media.preview_image | image_url: format: 'avif' }} {{ media.preview_image.width }}w"
      sizes="(min-width: 750px) calc(100vw - 22rem), 1100px"
    >

    {%- comment -%} WebP source — wide browser support fallback {%- endcomment -%}
    <source
      type="image/webp"
      srcset="{%- if media.preview_image.width >= 550 -%}{{ media.preview_image | image_url: width: 550, format: 'webp' }} 550w,{%- endif -%}
              {%- if media.preview_image.width >= 1100 -%}{{ media.preview_image | image_url: width: 1100, format: 'webp' }} 1100w,{%- endif -%}
              {%- if media.preview_image.width >= 1445 -%}{{ media.preview_image | image_url: width: 1445, format: 'webp' }} 1445w,{%- endif -%}
              {%- if media.preview_image.width >= 1680 -%}{{ media.preview_image | image_url: width: 1680, format: 'webp' }} 1680w,{%- endif -%}
              {%- if media.preview_image.width >= 2200 -%}{{ media.preview_image | image_url: width: 2200, format: 'webp' }} 2200w,{%- endif -%}
              {{ media.preview_image | image_url: format: 'webp' }} {{ media.preview_image.width }}w"
      sizes="(min-width: 750px) calc(100vw - 22rem), 1100px"
    >

    {%- comment -%} JPG fallback — universal compatibility {%- endcomment -%}
    <img
      class="global-media-settings global-media-settings--no-shadow{% if variant_image %} product__media-item--variant{% endif %}"
      srcset="{%- if media.preview_image.width >= 550 -%}{{ media.preview_image | image_url: width: 550 }} 550w,{%- endif -%}
              {%- if media.preview_image.width >= 1100 -%}{{ media.preview_image | image_url: width: 1100 }} 1100w,{%- endif -%}
              {%- if media.preview_image.width >= 1445 -%}{{ media.preview_image | image_url: width: 1445 }} 1445w,{%- endif -%}
              {%- if media.preview_image.width >= 1680 -%}{{ media.preview_image | image_url: width: 1680 }} 1680w,{%- endif -%}
              {%- if media.preview_image.width >= 2200 -%}{{ media.preview_image | image_url: width: 2200 }} 2200w,{%- endif -%}
              {{ media.preview_image | image_url }} {{ media.preview_image.width }}w"
      sizes="(min-width: 750px) calc(100vw - 22rem), 1100px"
      src="{{ media.preview_image | image_url: width: 1445 }}"
      alt="{{ img_alt }}"
      width="{{ img_width }}"
      height="{{ img_height }}"
      data-media-id="{{ media.id }}"
      {%- if is_hero -%}
        fetchpriority="high"
        decoding="sync"
      {%- else -%}
        loading="lazy"
        decoding="async"
      {%- endif -%}
    >
  </picture>
{%- else -%}
  {%- if media.media_type == 'model' -%}
    <div class="product-media-modal__model" data-media-id="{{ media.id }}">
      <product-model class="deferred-media media media--transparent global-media-settings global-media-settings--no-shadow" data-media-id="{{ media.id }}">
  {%- else -%}
    {%- assign safe_aspect_ratio = media.aspect_ratio | default: 1.0 -%}
    {%- if safe_aspect_ratio < 0.001 -%}
      {%- assign safe_aspect_ratio = 1.0 -%}
    {%- endif -%}
    {%- assign media_ratio_percent = 1 | divided_by: safe_aspect_ratio | times: 100 -%}
    <deferred-media class="deferred-media media global-media-settings global-media-settings--no-shadow" data-media-id="{{ media.id }}">
  {%- endif -%}

    <button id="Deferred-Poster-Modal-{{ media.id }}" class="deferred-media__poster" type="button">
      <span class="deferred-media__poster-button motion-reduce">
        {%- if media.media_type == 'model' -%}
          {%- render 'icon-3d-model' -%}
        {%- else -%}
          {%- render 'icon-play' -%}
        {%- endif -%}
      </span>
      <img
        srcset="{% if media.preview_image.width >= 288 %}{{ media.preview_image | image_url: width: 288 }} 288w,{% endif %}
                {% if media.preview_image.width >= 576 %}{{ media.preview_image | image_url: width: 576 }} 576w,{% endif %}
                {% if media.preview_image.width >= 550 %}{{ media.preview_image | image_url: width: 550 }} 550w,{% endif %}
                {% if media.preview_image.width >= 1100 %}{{ media.preview_image | image_url: width: 1100 }} 1100w,{% endif %}
                {{ media.preview_image | image_url }} {{ media.preview_image.width }}w"
        src="{{ media | image_url: width: 550, height: 550 }}"
        sizes="(min-width: 1200px) calc((1200px - 10rem) / 2), (min-width: 750px) calc((100vw - 11.5rem) / 2), calc(100vw - 4rem)"
        loading="lazy"
        decoding="async"
        width="576"
        height="{{ 576 | divided_by: media.preview_image.aspect_ratio }}"
        alt="{{ media.preview_image.alt | escape }}"
      >
    </button>
    <template>
      {%- case media.media_type -%}
      {%- when 'external_video' -%}
        {%- assign video_class = 'js-' | append: media.host -%}
        {%- if media.host == 'youtube' -%}
          {{ media | external_video_url: autoplay: true, loop: loop, playlist: media.external_id | external_video_tag: class: video_class, loading: "lazy" }}
        {%- else -%}
          {{ media | external_video_url: autoplay: true, loop: loop | external_video_tag: class: video_class, loading: "lazy" }}
        {%- endif -%}
      {%- when 'video' -%}
        {{ media | media_tag: image_size: "2048x", autoplay: true, loop: loop, controls: true, preload: "none" }}
      {%- when 'model' -%}
        {{ media | media_tag: image_size: "2048x", toggleable: true }}
      {%- endcase -%}
    </template>

  {%- if media.media_type == 'model' -%}
      </product-model>
      <button
        class="button button--full-width product__xr-button"
        type="button"
        aria-label="{{ 'products.product.xr_button_label' | t }}"
        data-shopify-xr
        data-shopify-model3d-id="{{ media.id }}"
        data-shopify-title="title"
        data-shopify-xr-hidden
        >
        {% render 'icon-3d-model' %}
        {{ 'products.product.xr_button' | t }}
      </button>
    </div>
  {%- else -%}
    </deferred-media>
  {%- endif -%}
{%- endif -%}
