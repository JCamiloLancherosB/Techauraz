<div class="shipping-timeline section-{{ section.id }}-padding">
  <div class="shipping-timeline__container page-width">
    {% if section.settings.heading != blank %}
      <h3 class="shipping-timeline__heading">{{ section.settings.heading }}</h3>
    {% endif %}

    {% if section.settings.description != blank %}
      <p class="shipping-timeline__description">{{ section.settings.description }}</p>
    {% endif %}

    <div class="shipping-timeline__track">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          <div class="shipping-timeline__step" {{ block.shopify_attributes }}>
            <div class="shipping-timeline__step-icon">
              {% if block.settings.emoji != blank %}
              {%- assign step_icon = block.settings.emoji -%}
              {%- if step_icon == 'package' or step_icon == 'shipping' or step_icon == 'check-circle' or step_icon == 'fire' or step_icon == 'sparkles' or step_icon == 'lock' or step_icon == 'star' or step_icon == 'lightning' or step_icon == 'guarantee' or step_icon == 'award' -%}
                {% render 'icon-system', icon: step_icon, size: 24, color: 'var(--ta-accent, #00D4AA)' %}
              {%- else -%}
                <span aria-hidden="true">{{ step_icon }}</span>
              {%- endif -%}
              {% else %}
                <span aria-hidden="true">✓</span>
              {% endif %}
            </div>
            <div class="shipping-timeline__step-content">
              <h4 class="shipping-timeline__step-title">{{ block.settings.title }}</h4>
              <p class="shipping-timeline__step-description">{{ block.settings.description }}</p>
              {% if block.settings.time != blank %}
                <span class="shipping-timeline__step-time">{{ block.settings.time }}</span>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% else %}
        {%- comment -%} Timeline por defecto {%- endcomment -%}
        <div class="shipping-timeline__step">
          <div class="shipping-timeline__step-icon">
            {% render 'icon-system', icon: 'package', size: 24, color: 'var(--ta-accent, #00D4AA)' %}
          </div>
          <div class="shipping-timeline__step-content">
            <h4 class="shipping-timeline__step-title">Procesamiento del Pedido</h4>
            <p class="shipping-timeline__step-description">Verificamos tu pago y preparamos tu pedido</p>
            <span class="shipping-timeline__step-time">1-2 días hábiles</span>
          </div>
        </div>

        <div class="shipping-timeline__step">
          <div class="shipping-timeline__step-icon">
            {% render 'icon-system', icon: 'shipping', size: 24, color: 'var(--ta-accent, #00D4AA)' %}
          </div>
          <div class="shipping-timeline__step-content">
            <h4 class="shipping-timeline__step-title">Envío</h4>
            <p class="shipping-timeline__step-description">Tu pedido sale hacia su destino</p>
            <span class="shipping-timeline__step-time">2-5 días hábiles</span>
          </div>
        </div>

        <div class="shipping-timeline__step">
          <div class="shipping-timeline__step-icon">
            {% render 'icon-system', icon: 'check-circle', size: 24, color: 'var(--ta-accent, #00D4AA)' %}
          </div>
          <div class="shipping-timeline__step-content">
            <h4 class="shipping-timeline__step-title">Entrega</h4>
            <p class="shipping-timeline__step-description">Recibe tu producto en la puerta de tu casa</p>
            <span class="shipping-timeline__step-time">¡Listo!</span>
          </div>
        </div>
      {% endif %}
    </div>

    {% if section.settings.footer_text != blank %}
      <p class="shipping-timeline__footer">{{ section.settings.footer_text }}</p>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Timeline de Envío",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Encabezado",
      "default": "¿Cómo funciona el envío?"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Descripción",
      "default": "Seguimiento paso a paso desde la compra hasta la entrega"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Texto al pie",
      "default": "* Tiempos estimados. Pueden variar según la ubicación."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado superior",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado inferior",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Paso",
      "settings": [
        {
          "type": "text",
          "id": "emoji",
          "label": "Emoji/Ícono",
          "default": "package",
          "info": "Usa un nombre de icono SVG (package, shipping, check-circle, fire, sparkles, lock, star, lightning, guarantee, award) o cualquier emoji"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Paso del proceso"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripción",
          "default": "Descripción de este paso del proceso de envío"
        },
        {
          "type": "text",
          "id": "time",
          "label": "Tiempo estimado",
          "default": "1-2 días",
          "info": "Ejemplo: '1-2 días hábiles'"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Timeline de Envío",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "emoji": "package",
            "title": "Procesamiento del Pedido",
            "description": "Verificamos tu pago y preparamos tu pedido con cuidado",
            "time": "1-2 días hábiles"
          }
        },
        {
          "type": "step",
          "settings": {
            "emoji": "shipping",
            "title": "Envío Nacional",
            "description": "Tu pedido sale hacia su destino con transportadora certificada",
            "time": "2-5 días hábiles"
          }
        },
        {
          "type": "step",
          "settings": {
            "emoji": "check-circle",
            "title": "Entrega a Domicilio",
            "description": "Recibe tu producto en la puerta de tu casa",
            "time": "¡Listo para usar!"
          }
        }
      ]
    }
  ]
}
{% endschema %}
