{% comment %}
  Conversion-Focused Benefits Strip
  
  Displays 4 benefit cards in a horizontal grid with icons and outcome-driven copy.
  Styled by visual-system-unified.css
{% endcomment %}

{%- liquid
  assign heading = section.settings.heading | default: '¿Por qué comprar con nosotros?'
-%}

<div class="page-width ta-conv-section-spacing">
  <h2 class="ta-conv-section-heading">{{ heading }}</h2>
  
  <div class="ta-conv-benefits">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'benefit' -%}
          <div class="ta-conv-benefit" {{ block.shopify_attributes }}>
            <div class="ta-conv-benefit__icon">
              {%- assign icon_val = block.settings.icon | default: 'sparkles' -%}
              {%- if icon_val == 'shipping' or icon_val == 'payment' or icon_val == 'guarantee' or icon_val == 'lightning' or icon_val == 'sparkles' or icon_val == 'rocket' or icon_val == 'diamond' or icon_val == 'lock' or icon_val == 'fire' or icon_val == 'package' -%}
                {% render 'icon-system', icon: icon_val, size: 32, color: 'var(--ta-accent, #00D4AA)' %}
              {%- else -%}
                {{ icon_val }}
              {%- endif -%}
            </div>
            <h3 class="ta-conv-benefit__title">{{ block.settings.title }}</h3>
            <p class="ta-conv-benefit__description">{{ block.settings.description }}</p>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Beneficios de Compra",
  "class": "section",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Muestra 4 beneficios en tarjetas horizontales con iconos y texto persuasivo."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título de la sección",
      "default": "¿Por qué comprar con nosotros?"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Beneficio",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icono (emoji)",
          "default": "sparkles",
          "info": "Usa un nombre de icono SVG (shipping, payment, guarantee, lightning, sparkles, lock, fire, check-circle, award, diamond) o cualquier emoji"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Beneficio importante"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripción",
          "default": "Describe el resultado positivo que obtiene el cliente con este beneficio."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Beneficios de Compra",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "shipping",
            "title": "Recibe gratis en tu casa",
            "description": "Sin costos ocultos ni sorpresas. El precio que ves es el que pagas, envío incluido a toda Colombia."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "payment",
            "title": "Paga cuando recibes",
            "description": "Inspecciona tu producto antes de pagar. Pago contra entrega disponible en todo el país."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "sparkles",
            "title": "30 días de garantía",
            "description": "Si no quedas satisfecho, devuélvelo sin preguntas. Tu satisfacción es nuestra prioridad."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "lightning",
            "title": "Entrega en 2-5 días",
            "description": "Procesamos y enviamos tu pedido el mismo día. Recíbelo rápidamente donde estés."
          }
        }
      ]
    }
  ]
}
{% endschema %}
