{% comment %}
  Trust Bar — Compact Benefits Strip
  
  Replaces the old oversized 4-card benefits section.
  Shows 4 trust signals in a single horizontal row (desktop)
  or a compact 2x2 grid (mobile) — total height: 56-100px.
  
  Styled by visual-system-unified.css (.ta-trust-bar-*)
{% endcomment %}

{%- liquid
  assign heading = section.settings.heading
-%}

<section class="ta-trust-bar" aria-label="Beneficios de compra">
  <div class="page-width">

    {%- if heading != blank -%}
      <h2 class="visually-hidden">{{ heading }}</h2>
    {%- endif -%}

    <div class="ta-trust-bar__grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'benefit' -%}
            <div class="ta-trust-bar__item" {{ block.shopify_attributes }}>
              <span class="ta-trust-bar__icon" aria-hidden="true">
                {%- assign icon_val = block.settings.icon | default: 'sparkles' -%}
                {%- if icon_val == 'shipping' or icon_val == 'payment' or icon_val == 'guarantee' or icon_val == 'lightning' or icon_val == 'sparkles' or icon_val == 'rocket' or icon_val == 'diamond' or icon_val == 'lock' or icon_val == 'fire' or icon_val == 'package' -%}
                  {% render 'icon-system', icon: icon_val, size: 20, color: 'currentColor' %}
                {%- else -%}
                  {{ icon_val }}
                {%- endif -%}
              </span>
              <span class="ta-trust-bar__text">
                <strong class="ta-trust-bar__title">{{ block.settings.title }}</strong>
                {%- if block.settings.description != blank -%}
                  <span class="ta-trust-bar__desc">{{ block.settings.description }}</span>
                {%- endif -%}
              </span>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Barra de Confianza",
  "class": "section section--trust-bar",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Barra compacta de beneficios. Muestra 4 señales de confianza en línea horizontal."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título (accesibilidad)",
      "default": "¿Por qué comprar con nosotros?",
      "info": "Se oculta visualmente pero los lectores de pantalla lo anuncian."
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Beneficio",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icono SVG",
          "default": "shipping",
          "info": "Nombres válidos: shipping, payment, guarantee, lightning, sparkles, lock, fire, package, rocket, diamond"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título corto",
          "default": "Envío Gratis"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripción (tooltip en desktop)",
          "default": "A toda Colombia, sin costos ocultos."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barra de Confianza",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "shipping",
            "title": "Envío Gratis",
            "description": "A toda Colombia, sin costos ocultos."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "payment",
            "title": "Paga al Recibir",
            "description": "Pago contra entrega en tu puerta."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "guarantee",
            "title": "Garantía 30 Días",
            "description": "Devolución sin complicaciones."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "lightning",
            "title": "Entrega 2-5 Días",
            "description": "Procesamos y enviamos rápido."
          }
        }
      ]
    }
  ]
}
{% endschema %}
