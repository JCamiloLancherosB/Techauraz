<style>
/* Modern Grid Layout for Trust Badges */
.trust-badges-premium {
  padding: 40px 0;
  background-color: #f8fafc; /* very light premium gray */
}
.trust-badges__container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}
.trust-badges__heading {
  text-align: center;
  font-size: 2rem;
  font-weight: 800;
  margin-bottom: 32px;
  color: #0f172a;
}
.trust-badges__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
  align-items: stretch;
}
.trust-badges__item {
  display: flex;
  flex-direction: row;
  align-items: center;
  text-align: left;
  background: #ffffff;
  border-radius: 16px;
  padding: 24px;
  box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.03);
  border: 1px solid #e2e8f0;
  transition: transform 0.25s ease, box-shadow 0.25s ease;
  gap: 16px;
}
.trust-badges__item:hover {
  transform: translateY(-4px);
  box-shadow: 0 10px 25px -5px rgba(0,0,0,0.08);
  border-color: #cbd5e1;
}
.trust-badges__icon {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56px;
  height: 56px;
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  border-radius: 14px;
  color: #2563eb;
}
.trust-badges__icon svg {
  width: 28px;
  height: 28px;
  fill: currentColor;
}
.trust-badges__content {
  display: flex;
  flex-direction: column;
}
.trust-badges__title {
  font-size: 1.15rem;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 4px;
  line-height: 1.2;
}
.trust-badges__text {
  font-size: 0.95rem;
  color: #64748b;
  line-height: 1.4;
}
@media (max-width: 768px) {
  .trust-badges__grid {
    grid-template-columns: 1fr;
  }
}
</style>

<div class="trust-badges-premium section-{{ section.id }}-padding">
  <div class="trust-badges__container">
    {% if section.settings.heading != blank %}
      <h3 class="trust-badges__heading">{{ section.settings.heading }}</h3>
    {% endif %}

    <div class="trust-badges__grid">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          <div class="trust-badges__item" {{ block.shopify_attributes }}>
            <div class="trust-badges__icon">
              {%- assign badge_icon = block.settings.emoji -%}
              {%- comment -%} We force render an icon. If they use an emoji physically, we override to a standard check. {%- endcomment -%}
              {%- if badge_icon == 'lock' or badge_icon == 'payment' or badge_icon == 'shipping' or badge_icon == 'check-circle' or badge_icon == 'guarantee' or badge_icon == 'star' or badge_icon == 'fire' or badge_icon == 'sparkles' or badge_icon == 'diamond' or badge_icon == 'award' or badge_icon == 'package' or badge_icon == 'lightning' -%}
                {% render 'icon-system', icon: badge_icon %}
              {%- else -%}
                {% render 'icon-system', icon: 'check-circle' %}
              {%- endif -%}
            </div>
            
            <div class="trust-badges__content">
              <span class="trust-badges__title">{{ block.settings.text }}</span>
              <span class="trust-badges__text">{{ block.settings.subtext }}</span>
            </div>
          </div>
        {% endfor %}
      {% else %}
        {%- comment -%} Badges de confianza premium por defecto {%- endcomment -%}
        <div class="trust-badges__item">
          <div class="trust-badges__icon">{% render 'icon-system', icon: 'lock' %}</div>
          <div class="trust-badges__content">
            <span class="trust-badges__title">Pago Seguro</span>
            <span class="trust-badges__text">Transacciones encriptadas SSL</span>
          </div>
        </div>
        
        <div class="trust-badges__item">
          <div class="trust-badges__icon">{% render 'icon-system', icon: 'payment' %}</div>
          <div class="trust-badges__content">
            <span class="trust-badges__title">Contra Entrega</span>
            <span class="trust-badges__text">Revisa y paga en la puerta de tu casa</span>
          </div>
        </div>

        <div class="trust-badges__item">
          <div class="trust-badges__icon">{% render 'icon-system', icon: 'shipping' %}</div>
          <div class="trust-badges__content">
            <span class="trust-badges__title">Envío Gratis</span>
            <span class="trust-badges__text">A todo el territorio nacional</span>
          </div>
        </div>

        <div class="trust-badges__item">
          <div class="trust-badges__icon">{% render 'icon-system', icon: 'guarantee' %}</div>
          <div class="trust-badges__content">
            <span class="trust-badges__title">Garantía Total</span>
            <span class="trust-badges__text">Satisfacción en 30 días sin complicaciones</span>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Sellos de Confianza",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Encabezado",
      "default": "¿Por qué comprar con nosotros?"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Sello",
      "settings": [
        {
          "type": "text",
          "id": "emoji",
          "label": "Icono (Vector)",
          "default": "shipping",
          "info": "Elige entre: lock, payment, shipping, check-circle, guarantee, star, diamond, lightning."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Título",
          "default": "Beneficio Premium"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtítulo de Soporte",
          "default": "Explica la ventaja de forma clara y directa."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sellos de Confianza Premium",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "emoji": "shipping",
            "text": "Recibe gratis en tu casa",
            "subtext": "Sin costos ocultos. Envío incluido a toda Colombia en compras de cualquier monto."
          }
        },
        {
          "type": "badge",
          "settings": {
            "emoji": "payment",
            "text": "Paga cuando recibes",
            "subtext": "Inspecciona tu producto antes de pagar. Pago contra entrega disponible en todo el país."
          }
        },
        {
          "type": "badge",
          "settings": {
            "emoji": "guarantee",
            "text": "Garantía de 30 días",
            "subtext": "Si no quedas 100% satisfecho, devuélvelo sin preguntas ni complicaciones."
          }
        },
        {
          "type": "badge",
          "settings": {
            "emoji": "lightning",
            "text": "Entrega en 2-5 días",
            "subtext": "Procesamos tu pedido el mismo día. Recíbelo rápido donde estés en Colombia."
          }
        }
      ]
    }
  ]
}
{% endschema %}
