<div class="trust-badges section-{{ section.id }}-padding">
  <div class="trust-badges__container page-width">
    {% if section.settings.heading != blank %}
      <h3 class="trust-badges__heading">{{ section.settings.heading }}</h3>
    {% endif %}

    <div class="trust-badges__grid">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          <div class="trust-badges__item" {{ block.shopify_attributes }}>
            {% if block.settings.icon_type == 'emoji' %}
              {%- assign badge_icon = block.settings.emoji -%}
              {%- if badge_icon == 'lock' or badge_icon == 'payment' or badge_icon == 'shipping' or badge_icon == 'check-circle' or badge_icon == 'guarantee' or badge_icon == 'star' or badge_icon == 'fire' or badge_icon == 'sparkles' or badge_icon == 'diamond' or badge_icon == 'award' or badge_icon == 'package' or badge_icon == 'lightning' -%}
                <span class="trust-badges__icon" aria-hidden="true">{% render 'icon-system', icon: badge_icon, size: 24, color: 'var(--ta-accent, #00D4AA)' %}</span>
              {%- else -%}
                <span class="trust-badges__icon" aria-hidden="true">{{ badge_icon }}</span>
              {%- endif -%}
            {% elsif block.settings.icon_type == 'svg' and block.settings.custom_svg != blank %}
              <div class="trust-badges__icon">{{ block.settings.custom_svg }}</div>
            {% elsif block.settings.icon_type == 'image' and block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 60 | image_tag: loading: 'lazy', alt: block.settings.text, class: 'trust-badges__image' }}
            {% endif %}
            {% if block.settings.text != blank %}
              <span class="trust-badges__text">{{ block.settings.text }}</span>
            {% endif %}
          </div>
        {% endfor %}
      {% else %}
        {%- comment -%} Badges de confianza por defecto {%- endcomment -%}
        <div class="trust-badges__item">
          <span class="trust-badges__icon" aria-hidden="true">{% render 'icon-system', icon: 'lock', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</span>
          <span class="trust-badges__text">Pago Seguro</span>
        </div>
        
        <div class="trust-badges__item">
          <span class="trust-badges__icon" aria-hidden="true">{% render 'icon-system', icon: 'payment', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</span>
          <span class="trust-badges__text">Todos los Medios de Pago</span>
        </div>

        <div class="trust-badges__item">
          <span class="trust-badges__icon" aria-hidden="true">{% render 'icon-system', icon: 'shipping', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</span>
          <span class="trust-badges__text">Envío Gratis</span>
        </div>

        <div class="trust-badges__item">
          <span class="trust-badges__icon" aria-hidden="true">{% render 'icon-system', icon: 'check-circle', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</span>
          <span class="trust-badges__text">Garantía 30 Días</span>
        </div>

        <div class="trust-badges__item">
          <span class="trust-badges__icon" aria-hidden="true">{% render 'icon-system', icon: 'payment', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</span>
          <span class="trust-badges__text">Pago Contra Entrega</span>
        </div>

        <div class="trust-badges__item">
          <span class="trust-badges__icon" aria-hidden="true">{% render 'icon-system', icon: 'star', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</span>
          <span class="trust-badges__text">+1000 Clientes Satisfechos</span>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Sellos de Confianza",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Encabezado",
      "default": "Compra con Confianza"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado superior",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado inferior",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Sello",
      "settings": [
        {
          "type": "select",
          "id": "icon_type",
          "label": "Tipo de ícono",
          "options": [
            {
              "value": "emoji",
              "label": "Emoji"
            },
            {
              "value": "image",
              "label": "Imagen"
            },
            {
              "value": "svg",
              "label": "SVG personalizado"
            }
          ],
          "default": "emoji"
        },
        {
          "type": "text",
          "id": "emoji",
          "label": "Emoji",
          "default": "lock",
          "info": "Usa un nombre de icono SVG (lock, payment, shipping, check-circle, guarantee, star, fire, sparkles, diamond, award, package, lightning) o cualquier emoji"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen",
          "info": "Solo se usa si el tipo de ícono es 'Imagen'"
        },
        {
          "type": "html",
          "id": "custom_svg",
          "label": "SVG personalizado",
          "info": "Solo se usa si el tipo de ícono es 'SVG personalizado'. Pega el código SVG completo aquí."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Sello de Confianza"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sellos de Confianza",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "icon_type": "emoji",
            "emoji": "lock",
            "text": "Pago Seguro SSL"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon_type": "emoji",
            "emoji": "payment",
            "text": "PSE, Tarjetas, Efectivo"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon_type": "emoji",
            "emoji": "shipping",
            "text": "Envío Gratis"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon_type": "emoji",
            "emoji": "check-circle",
            "text": "Garantía 30 Días"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon_type": "emoji",
            "emoji": "payment",
            "text": "Contraentrega Disponible"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon_type": "emoji",
            "emoji": "star",
            "text": "+1000 Clientes"
          }
        }
      ]
    }
  ]
}
{% endschema %}
