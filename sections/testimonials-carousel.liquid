{{ 'testimonials.css' | asset_url | stylesheet_tag }}

<section 
  class="testimonials-wall section-{{ section.id }}-padding"
  data-section-id="{{ section.id }}"
  aria-label="Testimonios de clientes"
  style="{% if section.settings.background_color != blank %}background-color: {{ section.settings.background_color }};{% endif %}"
>
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <div class="testimonials-wall__header">
        <h2 class="testimonials-wall__title {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="testimonials-wall__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="testimonials-wall__grid" role="list">
      {%- for block in section.blocks -%}
        <article 
          class="testimonials-wall__card"
          role="listitem"
          {{ block.shopify_attributes }}
          aria-label="Testimonio de {{ block.settings.customer_name | default: 'Cliente' }}"
        >
          {%- comment -%} Star Rating {%- endcomment -%}
          {%- if block.settings.rating > 0 -%}
            <div class="testimonials-wall__rating" aria-label="Calificación: {{ block.settings.rating }} de 5 estrellas">
              {%- for i in (1..5) -%}
                {%- if i <= block.settings.rating -%}
                  <svg class="testimonials-wall__star testimonials-wall__star--filled" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                  </svg>
                {%- else -%}
                  <svg class="testimonials-wall__star testimonials-wall__star--empty" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                  </svg>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- comment -%} Review Text {%- endcomment -%}
          {%- if block.settings.review_text != blank -%}
            <blockquote class="testimonials-wall__text">
              <p>{{ block.settings.review_text }}</p>
            </blockquote>
          {%- endif -%}

          {%- comment -%} Product Photo (optional UGC placeholder) {%- endcomment -%}
          {%- if block.settings.product_image != blank -%}
            <div class="testimonials-wall__product-image">
              <img
                src="{{ block.settings.product_image | image_url: width: 400 }}"
                alt="Producto reseñado"
                width="400"
                height="300"
                loading="lazy"
                decoding="async"
              >
            </div>
          {%- endif -%}

          {%- comment -%} Customer Info + Verified Badge {%- endcomment -%}
          <div class="testimonials-wall__customer">
            {%- if block.settings.customer_image != blank -%}
              <div class="testimonials-wall__avatar">
                <img
                  src="{{ block.settings.customer_image | image_url: width: 80, height: 80, crop: 'center' }}"
                  alt="{{ block.settings.customer_name | escape }}"
                  width="44"
                  height="44"
                  loading="lazy"
                  decoding="async"
                >
              </div>
            {%- else -%}
              <div class="testimonials-wall__avatar testimonials-wall__avatar--placeholder">
                <span aria-hidden="true">{{ block.settings.customer_name | default: 'C' | slice: 0, 1 | upcase }}</span>
              </div>
            {%- endif -%}
            
            <div class="testimonials-wall__customer-info">
              {%- if block.settings.customer_name != blank -%}
                <cite class="testimonials-wall__name">{{ block.settings.customer_name }}</cite>
              {%- endif -%}
              {%- if block.settings.customer_city != blank -%}
                <span class="testimonials-wall__city">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  {{ block.settings.customer_city }}
                </span>
              {%- endif -%}
            </div>
          </div>

          {%- comment -%} Verified Purchase Badge {%- endcomment -%}
          <div class="testimonials-wall__verified">
            <span class="testimonials-wall__verified-badge">✅ Compra Verificada</span>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Wall of Love",
  "tag": "section",
  "class": "section testimonials-wall-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Únete a +5,000 colombianos que ya mejoraron su setup 👇",
      "label": "Título de la sección"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo (opcional)",
      "default": "Reseñas reales de compradores verificados en toda Colombia"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Pequeño" },
        { "value": "h1", "label": "Mediano" },
        { "value": "h0", "label": "Grande" }
      ],
      "default": "h1",
      "label": "Tamaño del título"
    },
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#f8fafc"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado superior",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado inferior",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonio",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5,
          "label": "Calificación (estrellas)"
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Texto de la reseña",
          "default": "Excelente producto y servicio. Superó todas mis expectativas. Lo recomiendo totalmente."
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "Nombre del cliente",
          "default": "María García"
        },
        {
          "type": "text",
          "id": "customer_city",
          "label": "Ciudad del cliente",
          "default": "Bogotá",
          "info": "Ej: Bogotá, Medellín, Cali"
        },
        {
          "type": "image_picker",
          "id": "customer_image",
          "label": "Foto del cliente (opcional)",
          "info": "Foto real o avatar. 80x80px recomendado."
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Foto del producto/unboxing (opcional)",
          "info": "Imagen UGC del producto en mano del cliente. 400x300px recomendado."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Wall of Love",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "review_text": "Tenía miedo de pedir online, pero el Pago Contraentrega me dio confianza. Llegó en 3 días a Medellín y la calidad es brutal. 10/10.",
            "customer_name": "Carlos M.",
            "customer_city": "Medellín"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "review_text": "Los audífonos superaron mis expectativas. El sonido es cristalino y los uso diariamente. Ya es mi segunda compra en TechAura.",
            "customer_name": "Ana R.",
            "customer_city": "Bogotá"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "review_text": "Pedí la USB personalizada para un regalo corporativo y quedó perfecta. Ya encargamos 50 más para la oficina.",
            "customer_name": "Empresas Tech",
            "customer_city": "Cali"
          }
        }
      ]
    }
  ]
}
{% endschema %}
