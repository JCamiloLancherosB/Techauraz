<div class="product-benefits section-{{ section.id }}-padding">
  <div class="product-benefits__container page-width">
    {% if section.settings.heading != blank %}
      <h2 class="product-benefits__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.blocks.size > 0 %}
      <ul class="product-benefits__list">
        {% for block in section.blocks %}
          <li class="product-benefits__item" {{ block.shopify_attributes }}>
            {%- assign emoji_val = block.settings.emoji -%}
            {%- if emoji_val == 'fire' or emoji_val == 'shipping' or emoji_val == 'sparkles' or emoji_val == 'guarantee' or emoji_val == 'lightning' or emoji_val == 'lock' or emoji_val == 'star' or emoji_val == 'check-circle' or emoji_val == 'award' or emoji_val == 'diamond' or emoji_val == 'rocket' or emoji_val == 'package' -%}
              <span class="product-benefits__icon" aria-hidden="true">{% render 'icon-system', icon: emoji_val, size: 24, color: 'var(--ta-accent, #00D4AA)' %}</span>
            {%- else -%}
              <span class="product-benefits__icon" aria-hidden="true">{{ emoji_val }}</span>
            {%- endif -%}
            <div class="product-benefits__content">
              <h3 class="product-benefits__title">{{ block.settings.title }}</h3>
              <p class="product-benefits__description">{{ block.settings.description }}</p>
            </div>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      {%- comment -%} Beneficios por defecto si no hay bloques configurados {%- endcomment -%}
      <ul class="product-benefits__list">
        <li class="product-benefits__item">
          <span class="product-benefits__icon" aria-hidden="true">{% render 'icon-system', icon: 'fire', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</span>
          <div class="product-benefits__content">
            <h3 class="product-benefits__title">Alta Calidad</h3>
            <p class="product-benefits__description">Productos premium con la mejor calidad del mercado</p>
          </div>
        </li>
        <li class="product-benefits__item">
          <span class="product-benefits__icon" aria-hidden="true">{% render 'icon-system', icon: 'shipping', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</span>
          <div class="product-benefits__content">
            <h3 class="product-benefits__title">Envío Gratis</h3>
            <p class="product-benefits__description">Entrega rápida a todo Colombia sin costo adicional</p>
          </div>
        </li>
        <li class="product-benefits__item">
          <span class="product-benefits__icon" aria-hidden="true">{% render 'icon-system', icon: 'sparkles', size: 24, color: 'var(--ta-accent, #00D4AA)' %}</span>
          <div class="product-benefits__content">
            <h3 class="product-benefits__title">Garantía Total</h3>
            <p class="product-benefits__description">30 días de garantía en todos nuestros productos</p>
          </div>
        </li>
      </ul>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Beneficios del Producto",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Encabezado",
      "default": "¿Por qué elegir este producto?"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado superior",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado inferior",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Beneficio",
      "settings": [
        {
          "type": "text",
          "id": "emoji",
          "label": "Emoji",
          "default": "fire",
          "info": "Usa un nombre de icono SVG (fire, shipping, sparkles, guarantee, lightning, lock, star, award, diamond, rocket, package) o cualquier emoji"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Beneficio del Producto"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripción",
          "default": "Descripción del beneficio que obtiene el cliente"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Beneficios del Producto",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "emoji": "fire",
            "title": "Alta Calidad Premium",
            "description": "Productos fabricados con los mejores materiales del mercado"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "emoji": "shipping",
            "title": "Envío Gratis",
            "description": "Entrega rápida a toda Colombia sin costo adicional"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "emoji": "sparkles",
            "title": "Garantía 30 Días",
            "description": "Devolución sin preguntas si no quedas satisfecho"
          }
        }
      ]
    }
  ]
}
{% endschema %}
