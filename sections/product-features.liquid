<div class="product-features section-{{ section.id }}-padding">
  <div class="product-features__container page-width">
    {% if section.settings.heading != blank %}
      <h2 class="product-features__heading h3">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.blocks.size > 0 %}
      <ul class="product-features__list">
        {% for block in section.blocks %}
          <li class="product-features__item" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
            {%- assign icon_val = block.settings.icon -%}
            {%- if icon_val == 'lightning' or icon_val == 'usb' or icon_val == 'smartphone' or icon_val == 'headphones' or icon_val == 'watch' or icon_val == 'fire' or icon_val == 'shipping' or icon_val == 'sparkles' or icon_val == 'guarantee' or icon_val == 'lock' or icon_val == 'star' or icon_val == 'diamond' or icon_val == 'rocket' or icon_val == 'package' or icon_val == 'eye' -%}
              <span class="product-features__icon" aria-hidden="true">{% render 'icon-system', icon: icon_val, size: 20, color: 'var(--ta-accent, #00D4AA)' %}</span>
            {%- else -%}
              <span class="product-features__icon" aria-hidden="true">{{ icon_val }}</span>
            {%- endif -%}
            {% endif %}
            <div class="product-features__content">
              {% if block.settings.label != blank %}
                <span class="product-features__label">{{ block.settings.label }}:</span>
              {% endif %}
              <span class="product-features__value">{{ block.settings.value }}</span>
            </div>
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Características Técnicas",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Encabezado",
      "default": "Especificaciones Técnicas"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado superior",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado inferior",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Característica",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icono (emoji)",
          "default": "lightning",
          "info": "Usa un nombre de icono SVG (lightning, usb, smartphone, headphones, watch, fire, shipping, sparkles, lock, star, diamond, package) o cualquier emoji"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etiqueta",
          "default": "Procesador"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Valor",
          "default": "Dual Core 1.2GHz"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Características Técnicas",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "lightning",
            "label": "Procesador",
            "value": "Dual Core 1.2GHz"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "usb",
            "label": "Memoria",
            "value": "32GB / 64GB"
          }
        }
      ]
    }
  ]
}
{% endschema %}
