<link rel="stylesheet" href="{{ 'section-category-navigation.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="{{ 'section-category-navigation.css' | asset_url }}"></noscript>

<div class="category-nav-section">
  <div class="category-nav-wrapper">
    {%- if section.settings.heading != blank -%}
      <h2 class="category-nav-title">{{ section.settings.heading }}</h2>
    {%- endif -%}
    
    {%- if section.settings.subtitle != blank -%}
      <p class="category-nav-subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    
    <div class="category-nav-grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'category' -%}
            <a href="{{ block.settings.link }}" class="category-card{% if forloop.first %} category-card--featured{% endif %}" {{ block.shopify_attributes }}>
              {%- if block.settings.image -%}
                <div class="category-card__image">
                  {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', sizes: '(max-width: 749px) 50vw, 20vw' }}
                </div>
              {%- else -%}
                <div class="category-card__image category-card__image--placeholder">
                  {%- assign cat_icon = block.settings.icon | default: 'sparkles' -%}
                  {%- if cat_icon == 'headphones' or cat_icon == 'watch' or cat_icon == 'usb' or cat_icon == 'smartphone' or cat_icon == 'lightbulb' or cat_icon == 'shipping' or cat_icon == 'payment' or cat_icon == 'guarantee' or cat_icon == 'lightning' or cat_icon == 'sparkles' or cat_icon == 'rocket' or cat_icon == 'diamond' or cat_icon == 'lock' or cat_icon == 'fire' or cat_icon == 'package' -%}
                    {% render 'icon-system', icon: cat_icon, size: 48, color: 'var(--ta-accent, #00D4AA)' %}
                  {%- else -%}
                    <span class="category-card__emoji" aria-hidden="true">{{ cat_icon }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}

              <div class="category-card__overlay"></div>

              <div class="category-card__content">
                {%- if block.settings.badge != blank -%}
                  <span class="category-card__badge">{{ block.settings.badge }}</span>
                {%- endif -%}
                
                {%- if block.settings.title != blank -%}
                  <h3 class="category-card__name">{{ block.settings.title }}</h3>
                {%- endif -%}

                {%- if block.settings.subtitle != blank -%}
                  <p class="category-card__subtitle">{{ block.settings.subtitle }}</p>
                {%- endif -%}
              </div>
            </a>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Navegación de Categorías",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Explora por Categoría"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo (opcional)",
      "info": "Agrega una descripción breve para dar contexto a los visitantes",
      "default": ""
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoría",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen de categoría",
          "info": "Usa una foto lifestyle del producto. Tamaño recomendado: 600x400px"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icono fallback (si no hay imagen)",
          "default": "headphones",
          "info": "Nombre de icono SVG (headphones, watch, usb, smartphone, lightbulb) o emoji"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Nombre de Categoría",
          "default": "Audífonos"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtítulo (opcional)",
          "info": "Ej: 'Desde $49.900'"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge (opcional)",
          "info": "Ej: 'Trending 🔥' o 'Nuevo'. Déjalo vacío para no mostrar badge."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Navegación de Categorías",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "icon": "headphones",
            "title": "Audífonos",
            "badge": "Trending 🔥"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon": "watch",
            "title": "Smart Watches"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon": "usb",
            "title": "Memorias USB"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon": "smartphone",
            "title": "Accesorios"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon": "lightbulb",
            "title": "Iluminación"
          }
        }
      ]
    }
  ]
}
{% endschema %}
