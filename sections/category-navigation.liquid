<style>
/* Modern Glassmorphic Tech Grid for Categories */
.category-nav-section {
  padding: 60px 0;
  background-color: #ffffff;
}
.category-nav-wrapper {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}
.category-nav-title {
  text-align: center;
  font-size: 2.2rem;
  font-weight: 800;
  margin-bottom: 8px;
  color: #0f172a;
}
.category-nav-subtitle {
  text-align: center;
  font-size: 1.1rem;
  color: #64748b;
  margin-bottom: 40px;
}
.category-nav-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}
.category-card {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-decoration: none;
  background: #f8fafc;
  border-radius: 16px;
  padding: 32px 16px;
  min-height: 220px;
  position: relative;
  overflow: hidden;
  border: 1px solid #e2e8f0;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);
}
.category-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 15px 30px -5px rgba(0,0,0,0.08);
  border-color: #cbd5e1;
  background: #ffffff;
}
.category-card__image {
  margin-bottom: 20px;
  width: 72px;
  height: 72px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20px;
  background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%); /* sleek tech slate tint */
  color: #0f172a;
  transition: transform 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
}
.category-card:hover .category-card__image {
  transform: scale(1.1);
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); /* deep premium tech dark */
  color: #ffffff;
  box-shadow: 0 8px 20px rgba(15, 23, 42, 0.15);
}
.category-card__image svg {
  width: 36px;
  height: 36px;
  fill: currentColor;
}
.category-card__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: inherit;
}
.category-card__content {
  text-align: center;
  z-index: 2;
}
.category-card__badge {
  position: absolute;
  top: 12px;
  right: 12px;
  background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);
  color: white;
  font-size: 0.65rem;
  font-weight: 700;
  padding: 4px 8px;
  border-radius: 20px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  box-shadow: 0 2px 4px rgba(239, 68, 68, 0.3);
}
.category-card__name {
  font-size: 1.25rem;
  font-weight: 700;
  color: #1e293b;
  margin: 0 0 6px 0;
}
.category-card__subtitle {
  font-size: 0.9rem;
  color: #64748b;
  margin: 0;
  font-weight: 500;
}
/* Responsive overrides */
@media (max-width: 768px) {
  .category-nav-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .category-nav-title {
    font-size: 1.8rem;
  }
  .category-card {
    min-height: 180px;
    padding: 24px 12px;
  }
  .category-card__image {
    width: 56px;
    height: 56px;
  }
  .category-card__image svg {
    width: 28px;
    height: 28px;
  }
}
</style>

<div class="category-nav-section">
  <div class="category-nav-wrapper">
    {%- if section.settings.heading != blank -%}
      <h2 class="category-nav-title">{{ section.settings.heading }}</h2>
    {%- endif -%}
    
    {%- if section.settings.subtitle != blank -%}
      <p class="category-nav-subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    
    <div class="category-nav-grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'category' -%}
            <a href="{{ block.settings.link }}" class="category-card" {{ block.shopify_attributes }}>
              {%- if block.settings.badge != blank -%}
                <span class="category-card__badge">{{ block.settings.badge }}</span>
              {%- endif -%}

              <div class="category-card__image">
                {%- if block.settings.image -%}
                  {{ block.settings.image | image_url: width: 300 | image_tag: loading: 'lazy' }}
                {%- else -%}
                  {%- assign cat_icon = block.settings.icon | default: 'sparkles' -%}
                  {%- if cat_icon == 'headphones' or cat_icon == 'watch' or cat_icon == 'usb' or cat_icon == 'smartphone' or cat_icon == 'lightbulb' or cat_icon == 'shipping' or cat_icon == 'payment' or cat_icon == 'guarantee' or cat_icon == 'lightning' or cat_icon == 'sparkles' or cat_icon == 'rocket' or cat_icon == 'diamond' or cat_icon == 'lock' or cat_icon == 'fire' or cat_icon == 'package' -%}
                    {% render 'icon-system', icon: cat_icon %}
                  {%- else -%}
                    {%- comment -%} Forced standard generic SVG to avoid emoji completely {%- endcomment -%}
                    <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" class="css-i6dzq1"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                  {%- endif -%}
                {%- endif -%}
              </div>

              <div class="category-card__content">
                {%- if block.settings.title != blank -%}
                  <h3 class="category-card__name">{{ block.settings.title }}</h3>
                {%- endif -%}

                {%- if block.settings.subtitle != blank -%}
                  <p class="category-card__subtitle">{{ block.settings.subtitle }}</p>
                {%- else -%}
                  {%- comment -%} Auto-populate product count from linked collection {%- endcomment -%}
                  {%- assign cat_link_str = block.settings.link | default: '' -%}
                  {%- if cat_link_str contains '/collections/' -%}
                    {%- assign cat_handle = cat_link_str | split: '/collections/' | last | split: '?' | first -%}
                    {%- assign cat_collection = collections[cat_handle] -%}
                    {%- if cat_collection != blank and cat_collection.products_count > 0 -%}
                      <p class="category-card__subtitle">{{ cat_collection.products_count }} {% if cat_collection.products_count == 1 %}producto{% else %}productos{% endif %}</p>
                    {%- endif -%}
                  {%- endif -%}
                {%- endif -%}
              </div>
            </a>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Categorías Premium",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Explora por Categoría"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo (opcional)",
      "info": "Agrega una descripción breve para dar contexto a los visitantes"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoría",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen de categoría",
          "info": "Usa una foto cuadrada de alto contraste (opcional)"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icono de sistema (sin imagen)",
          "default": "headphones",
          "info": "Ejemplo: headphones, watch, usb, smartphone, lightbulb"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Nombre de Categoría",
          "default": "Audífonos"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtítulo (opcional)",
          "info": "Ej: 'Novedades de Abril'"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge Promocional (opcional)",
          "info": "Ej: 'Trending' o 'Sale'"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace a la Colección"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Navegación de Categorías",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "icon": "headphones",
            "title": "Audífonos",
            "badge": "Recomendado"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon": "watch",
            "title": "Smart Watches"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon": "usb",
            "title": "Memorias USB"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon": "smartphone",
            "title": "Accesorios"
          }
        }
      ]
    }
  ]
}
{% endschema %}
