{{ 'section-category-navigation.css' | asset_url | stylesheet_tag }}

<div class="category-nav-section">
  <div class="category-nav-wrapper">
    {%- if section.settings.heading != blank -%}
      <h2 class="category-nav-title">{{ section.settings.heading }}</h2>
    {%- endif -%}
    
    {%- if section.settings.subtitle != blank -%}
      <p class="category-nav-subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    
    <div class="category-nav-grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'category' -%}
            <a href="{{ block.settings.link }}" class="category-card" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                <div class="category-icon" aria-hidden="true">
                  {%- assign cat_icon = block.settings.icon -%}
                  {%- if cat_icon == 'headphones' or cat_icon == 'watch' or cat_icon == 'usb' or cat_icon == 'smartphone' or cat_icon == 'lightbulb' or cat_icon == 'shipping' or cat_icon == 'payment' or cat_icon == 'guarantee' or cat_icon == 'lightning' or cat_icon == 'sparkles' or cat_icon == 'rocket' or cat_icon == 'diamond' or cat_icon == 'lock' or cat_icon == 'fire' or cat_icon == 'package' -%}
                    {% render 'icon-system', icon: cat_icon, size: 28, color: 'var(--ta-accent, #00D4AA)' %}
                  {%- else -%}
                    {{ cat_icon }}
                  {%- endif -%}
                </div>
              {%- endif -%}
              
              {%- if block.settings.title != blank -%}
                <h3 class="category-name">{{ block.settings.title }}</h3>
              {%- endif -%}
              
              {%- if block.settings.product_count != blank -%}
                <p class="category-count">{{ 'sections.category_navigation.products_count' | t: count: block.settings.product_count }}</p>
              {%- endif -%}
            </a>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Navegación de Categorías",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Explora por Categoría"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo (opcional)",
      "info": "Agrega una descripción breve para dar contexto a los visitantes",
      "default": ""
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoría",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icono (emoji o símbolo)",
          "default": "🎧"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Nombre de Categoría",
          "default": "Audífonos"
        },
        {
          "type": "text",
          "id": "product_count",
          "label": "Cantidad de Productos (manual)",
          "info": "Se usa solo si no se selecciona una colección"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Colección",
          "info": "Selecciona una colección para mostrar el conteo real de productos automáticamente"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Navegación de Categorías",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "icon": "🎧",
            "title": "Audífonos",
            "product_count": "25"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon": "⌚",
            "title": "Smart Watches",
            "product_count": "18"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon": "💾",
            "title": "Memorias USB",
            "product_count": "30"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon": "📱",
            "title": "Accesorios",
            "product_count": "40"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon": "💡",
            "title": "Iluminación",
            "product_count": "15"
          }
        }
      ]
    }
  ]
}
{% endschema %}
