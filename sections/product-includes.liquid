<div class="product-includes section-{{ section.id }}-padding">
  <div class="product-includes__container page-width">
    {% if section.settings.heading != blank %}
      <h3 class="product-includes__heading">{{ section.settings.heading }}</h3>
    {% endif %}

    {% if section.settings.description != blank %}
      <p class="product-includes__description">{{ section.settings.description }}</p>
    {% endif %}

    <div class="product-includes__grid">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          <div class="product-includes__item" {{ block.shopify_attributes }}>
            <div class="product-includes__item-icon">
              {% if block.settings.emoji != blank %}
                <span aria-hidden="true">{{ block.settings.emoji }}</span>
              {% else %}
                <span aria-hidden="true">✓</span>
              {% endif %}
            </div>
            <div class="product-includes__item-content">
              <h4 class="product-includes__item-title">{{ block.settings.title }}</h4>
              {% if block.settings.description != blank %}
                <p class="product-includes__item-description">{{ block.settings.description }}</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% else %}
        {%- comment -%} Contenido por defecto {%- endcomment -%}
        <div class="product-includes__item">
          <div class="product-includes__item-icon">
            <span aria-hidden="true">📦</span>
          </div>
          <div class="product-includes__item-content">
            <h4 class="product-includes__item-title">Producto Principal</h4>
            <p class="product-includes__item-description">El artículo principal en perfectas condiciones</p>
          </div>
        </div>

        <div class="product-includes__item">
          <div class="product-includes__item-icon">
            <span aria-hidden="true">📖</span>
          </div>
          <div class="product-includes__item-content">
            <h4 class="product-includes__item-title">Manual de Usuario</h4>
            <p class="product-includes__item-description">Instrucciones completas en español</p>
          </div>
        </div>

        <div class="product-includes__item">
          <div class="product-includes__item-icon">
            <span aria-hidden="true">🔌</span>
          </div>
          <div class="product-includes__item-content">
            <h4 class="product-includes__item-title">Cable USB</h4>
            <p class="product-includes__item-description">Cable de carga de alta calidad</p>
          </div>
        </div>

        <div class="product-includes__item">
          <div class="product-includes__item-icon">
            <span aria-hidden="true">✅</span>
          </div>
          <div class="product-includes__item-content">
            <h4 class="product-includes__item-title">Garantía</h4>
            <p class="product-includes__item-description">Certificado de garantía de 30 días</p>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Qué Incluye el Producto",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Encabezado",
      "default": "📦 ¿Qué incluye tu compra?"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripción",
      "default": "Todo lo que recibirás al hacer tu pedido"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado superior",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado inferior",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Artículo Incluido",
      "settings": [
        {
          "type": "text",
          "id": "emoji",
          "label": "Emoji/Ícono",
          "default": "✓",
          "info": "Usa cualquier emoji como ícono"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Artículo incluido"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripción",
          "default": "Descripción breve del artículo incluido"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Qué Incluye el Producto",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "emoji": "📦",
            "title": "Producto Principal",
            "description": "El artículo principal en empaque original sellado"
          }
        },
        {
          "type": "item",
          "settings": {
            "emoji": "📖",
            "title": "Manual de Usuario",
            "description": "Instrucciones completas en español"
          }
        },
        {
          "type": "item",
          "settings": {
            "emoji": "🔌",
            "title": "Cable USB",
            "description": "Cable de carga y transferencia de datos"
          }
        },
        {
          "type": "item",
          "settings": {
            "emoji": "✅",
            "title": "Garantía 30 Días",
            "description": "Certificado de garantía oficial"
          }
        }
      ]
    }
  ]
}
{% endschema %}
