{% schema %}
{
  "name": "USB Formulario",
  "tag": "section",
  "class": "usb-landing usb-form-section",
  "settings": [
    { "type": "text", "id": "title", "label": "Título", "default": "Solicita tu Cotización" },
    { "type": "textarea", "id": "intro", "label": "Texto introductorio", "default": "Completa el formulario y te respondemos dentro de 24h hábiles." }
  ],
  "presets": [{ "name": "USB Formulario" }]
}
{% endschema %}

<div class="usb-landing" id="usb-form">
  <section class="usb-section alt" data-animate>
    <div class="usb-container">
      <div class="usb-form-box">
        <h2>{{ section.settings.title }}</h2>
        <p>{{ section.settings.intro }}</p>

        {% form 'contact', id: 'usb-quote-form', class: 'usb-form' %}
          {% if form.posted_successfully? %}
            <p class="usb-form__success">✅ Gracias, hemos recibido tu solicitud. Te contactaremos pronto.</p>
          {% endif %}

          {% if form.errors %}
            <ul class="usb-form__errors" role="alert">
              {% for field in form.errors %}
                <li>{{ form.errors.messages[field] }}</li>
              {% endfor %}
            </ul>
          {% endif %}

          <div class="grid">
            <label>
              <span>Nombre *</span>
              <input
                required
                type="text"
                name="contact[name]"
                value="{{ form.contact.name | default: customer.name }}"
                aria-label="Nombre completo"
                autocomplete="name"
              >
            </label>

            <label>
              <span>Email *</span>
              <input
                required
                type="email"
                name="contact[email]"
                value="{{ form.contact.email | default: customer.email }}"
                aria-label="Correo electrónico"
                autocomplete="email"
              >
            </label>

            <label>
              <span>Teléfono</span>
              <input
                type="tel"
                name="contact[phone]"
                value=""
                aria-label="Número de teléfono"
                autocomplete="tel"
              >
            </label>

            <label>
              <span>Empresa</span>
              <input
                type="text"
                name="contact[company]"
                value=""
                aria-label="Nombre de empresa"
                autocomplete="organization"
              >
            </label>

            <label>
              <span>Capacidad</span>
              <select name="contact[Capacidad]" aria-label="Capacidad de la USB">
                <option value="">Selecciona</option>
                <option>8GB</option>
                <option>16GB</option>
                <option>32GB</option>
                <option>64GB</option>
                <option>128GB</option>
                <option>256GB</option>
              </select>
            </label>

            <label>
              <span>Cantidad Estimada</span>
              <input
                type="number"
                min="50"
                step="50"
                name="contact[Cantidad]"
                value=""
                aria-label="Cantidad estimada de unidades"
                placeholder="Mínimo 50 unidades"
              >
            </label>

            <label class="full">
              <span>Comentarios / Uso</span>
              <textarea
                rows="4"
                name="contact[Comentarios]"
                placeholder="Ej: Evento corporativo en octubre, requerimos doble cara."
                aria-label="Comentarios adicionales sobre el uso"
              ></textarea>
            </label>
          </div>

          <button type="submit" class="usb-btn">Enviar Cotización</button>
        {% endform %}
      </div>
    </div>
  </section>
</div>