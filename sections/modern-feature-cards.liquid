{% comment %}
  Unified Benefits Section (Modern Feature Cards)
  
  CONSOLIDATED SECTION: This section replaces both benefits-conversion.liquid 
  and the previous modern-feature-cards.liquid for better organization.
  
  A modern store look with clean cards, clear CTAs, and responsive grid.
  Designed for conversion-focused product features and service highlights.
  Pattern: icon → title → 1 strong line → link (scannability optimized)
  
  Accepts:
  - heading: {String} Section heading
  - subheading: {String} Optional subheading
  - show_main_cta: {Boolean} Show unified CTA button
  - main_cta_text: {String} Main CTA button text
  - main_cta_link: {URL} Main CTA link
  - cards: {Array} Array of feature card objects
{% endcomment %}

{{ 'section-modern-feature-cards.css' | asset_url | stylesheet_tag }}

<section class="modern-feature-cards">
  <div class="modern-feature-cards__wrapper">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="modern-feature-cards__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="modern-feature-cards__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        
        {%- if section.settings.subheading != blank -%}
          <p class="modern-feature-cards__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
    
    {%- if section.blocks.size > 0 -%}
      <div class="modern-feature-cards__grid {% if section.blocks.size > 3 %}modern-feature-cards__grid--many{% endif %}">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'card' -%}
              <div class="modern-feature-card" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  <div class="modern-feature-card__icon" aria-hidden="true">
                    {%- assign fc_icon = block.settings.icon -%}
                    {%- if fc_icon == 'shipping' or fc_icon == 'payment' or fc_icon == 'guarantee' or fc_icon == 'lightning' or fc_icon == 'sparkles' or fc_icon == 'rocket' or fc_icon == 'diamond' or fc_icon == 'lock' or fc_icon == 'fire' or fc_icon == 'package' or fc_icon == 'headset' or fc_icon == 'check-circle' or fc_icon == 'award' or fc_icon == 'truck-fast' or fc_icon == 'headphones' or fc_icon == 'watch' or fc_icon == 'usb' or fc_icon == 'smartphone' or fc_icon == 'lightbulb' -%}
                      {% render 'icon-system', icon: fc_icon, size: 32, color: 'var(--ta-accent, #00D4AA)' %}
                    {%- else -%}
                      {{ fc_icon }}
                    {%- endif -%}
                  </div>
                {%- endif -%}
                
                {%- if block.settings.title != blank -%}
                  <h3 class="modern-feature-card__title">{{ block.settings.title }}</h3>
                {%- endif -%}
                
                {%- if block.settings.description != blank -%}
                  <p class="modern-feature-card__description">{{ block.settings.description }}</p>
                {%- endif -%}
                
                {%- if block.settings.cta_text != blank and block.settings.cta_link != blank -%}
                  <a href="{{ block.settings.cta_link }}" class="modern-feature-card__cta">
                    {{ block.settings.cta_text }}
                    <span class="modern-feature-card__cta-arrow" aria-hidden="true">→</span>
                  </a>
                {%- endif -%}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
    
    {%- comment -%} Unified CTA - Conversion focused {%- endcomment -%}
    {%- if section.settings.show_main_cta and section.settings.main_cta_text != blank and section.settings.main_cta_link != blank -%}
      <div class="modern-feature-cards__main-cta">
        <a href="{{ section.settings.main_cta_link }}" class="modern-feature-cards__main-cta-button">
          {{ section.settings.main_cta_text }}
          <span class="modern-feature-cards__cta-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Beneficios Unificados",
  "class": "section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título de la sección",
      "default": "¿Por qué comprar con nosotros?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo (opcional)",
      "default": "Descubre por qué miles de clientes confían en nosotros"
    },
    {
      "type": "header",
      "content": "CTA Principal"
    },
    {
      "type": "checkbox",
      "id": "show_main_cta",
      "label": "Mostrar botón CTA principal",
      "default": true,
      "info": "Un botón único de conversión al final de la sección"
    },
    {
      "type": "text",
      "id": "main_cta_text",
      "label": "Texto del botón CTA",
      "default": "Compra con contraentrega"
    },
    {
      "type": "url",
      "id": "main_cta_link",
      "label": "Enlace del botón CTA",
      "default": "shopify://collections/all"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Beneficio",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icono (emoji)",
          "default": "sparkles",
          "info": "Usa un nombre de icono SVG (shipping, payment, guarantee, lightning, sparkles, rocket, diamond, lock, fire, package, check-circle, award) o cualquier emoji"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Beneficio Clave"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripción breve",
          "default": "Una línea fuerte describiendo el beneficio para el cliente.",
          "info": "Mantén la descripción corta y persuasiva (1-2 líneas)"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "Texto del enlace (opcional)",
          "default": "",
          "info": "Enlace opcional para cada tarjeta"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "Enlace (opcional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Beneficios Unificados",
      "settings": {
        "heading": "¿Por qué comprar con nosotros?",
        "subheading": "Tecnología premium con la mejor experiencia de compra",
        "show_main_cta": true,
        "main_cta_text": "Compra con contraentrega",
        "main_cta_link": "shopify://collections/all"
      },
      "blocks": [
        {
          "type": "card",
          "settings": {
            "icon": "shipping",
            "title": "Recibe gratis en tu casa",
            "description": "Envío sin costo a toda Colombia. El precio que ves es el que pagas.",
            "cta_text": "Ver envíos",
            "cta_link": "shopify://collections/all"
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "payment",
            "title": "Paga cuando recibes",
            "description": "Pago contra entrega disponible. Inspecciona antes de pagar.",
            "cta_text": "",
            "cta_link": ""
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "check-circle",
            "title": "30 días de garantía",
            "description": "Si no quedas satisfecho, devuélvelo sin preguntas.",
            "cta_text": "",
            "cta_link": ""
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "lightning",
            "title": "Entrega en 2-5 días",
            "description": "Procesamos tu pedido el mismo día. Recíbelo rápido.",
            "cta_text": "Más vendidos",
            "cta_link": "shopify://collections/all"
          }
