<noscript><link rel="stylesheet" href="{{ 'techauraz-custom-ui.css' | asset_url }}"></noscript>

{%- if template.name == 'index' -%}
  <!-- Slideshow Enhancements - Controls & CTAs (HOME ONLY) -->
  <link rel="preload" href="{{ 'slideshow-enhancements.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="{{ 'slideshow-enhancements.css' | asset_url }}"></noscript>
{%- endif -%}

{%- if template.name == 'index' or template.name == 'collection' or template.name == 'search' or template.name == 'product' or template.name == 'cart' -%}
