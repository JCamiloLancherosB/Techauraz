    {%- comment -%}
      NON-CRITICAL SCRIPTS — Lazy loaded via requestIdleCallback
      These scripts enhance UX but are NOT needed for initial render.
      Loading them idle reduces main-thread Script Evaluation by ~400-600ms.
    {%- endcomment -%}
    <script>
    (function(){
      function lazyLoad(src){var s=document.createElement('script');s.src=src;s.defer=true;document.body.appendChild(s);}
      var idle=window.requestIdleCallback||function(cb){setTimeout(cb,200)};
      idle(function(){
        var agregarCar=document.querySelector('.product-form__submit[id*="ProductSubmitButton"]');
        if(agregarCar){agregarCar.classList.remove('button--full-width','button--secondary');}
        lazyLoad({{ 'techauraz-custom-ui.js' | asset_url | json }});
        lazyLoad({{ 'header-scroll-handler.js' | asset_url | json }});
        lazyLoad({{ 'scroll-reveal.js' | asset_url | json }});
        lazyLoad({{ 'micro-interactions.js' | asset_url | json }});
        lazyLoad({{ 'image-loading.js' | asset_url | json }});
        lazyLoad({{ 'tiny-img-link-preloader.js' | asset_url | json }});
        lazyLoad({{ 'speculative-prefetch.js' | asset_url | json }});
        lazyLoad({{ 'view-transitions.js' | asset_url | json }});
        lazyLoad({{ 'performance-monitor.js' | asset_url | json }});
        {%- if template.name == 'product' or template.name == 'collection' or template.name == 'index' -%}
        lazyLoad({{ 'exit-intent-recovery.js' | asset_url | json }});
        lazyLoad({{ 'gtm-ecommerce.js' | asset_url | json }});
        {%- endif -%}
        lazyLoad({{ 'bfcache-optimizer.js' | asset_url | json }});
        {%- if template.name == 'index' -%}
        lazyLoad({{ 'slideshow-autoplay-force.js' | asset_url | json }});\r
        {%- endif -%}
        {%- comment -%}
          DISABLED (2026-03-26): social-proof-toast.js generated fake purchase notifications
          with fabricated names, cities, and "Compra verificada" badges. This is a deceptive
          dark pattern that poses legal risk (SIC Colombia) and can cause Meta/Google Ads rejection.
          To re-enable with REAL data, integrate Shopify Order API or a verified social proof app.
        {%- endcomment -%}
        {%- comment -%} lazyLoad({{ 'social-proof-toast.js' | asset_url | json }}); {%- endcomment -%}
      });
    })();
    </script>

