<!-- Header, Announcement Bar & Slideshow UI/UX Fixes - 2026-02-04 -->
<link rel="preload" href="{{ 'header-announcement-slideshow-fixes.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript><link rel="stylesheet" href="{{ 'header-announcement-slideshow-fixes.css' | asset_url }}"></noscript>

<!-- Accessibility - Focus indicators, touch targets, WCAG 2.2 AA -->
<link rel="preload" href="{{ 'techauraz-accessibility.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript><link rel="stylesheet" href="{{ 'techauraz-accessibility.css' | asset_url }}"></noscript>


{%- if template.name == 'index' or template.name == 'collection' or template.name == 'search' -%}
  <!-- Quick View Modal - Product preview modal styles (PAGES WITH PRODUCT CARDS ONLY) -->
  <link rel="preload" href="{{ 'quick-view-modal.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="{{ 'quick-view-modal.css' | asset_url }}"></noscript>
{%- endif -%}

{%- if template.name == 'product' or template.suffix == 'comparison' -%}
  <!-- Product Comparison - Side-by-side product comparison feature (PDP & COMPARISON PAGES ONLY) -->
  <link rel="preload" href="{{ 'product-comparison.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
