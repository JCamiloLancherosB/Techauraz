<script>
// Auto-defer Shopify-injected render-blocking stylesheets
// Targets: accelerated-checkout-backwards-compat.css
(function(){
  var defined = {};
  document.querySelectorAll('link[rel="stylesheet"]').forEach(function(l){
    if(l.href && l.href.indexOf('accelerated-checkout') > -1){
      l.media = 'print';
      l.onload = function(){ this.media = 'all'; };
      defined[l.href] = true;
    }
  });
  var obs = new MutationObserver(function(ms){
    ms.forEach(function(m){
      m.addedNodes.forEach(function(n){
        if(n.tagName === 'LINK' && n.rel === 'stylesheet'
           && n.href && n.href.indexOf('accelerated-checkout') > -1
           && !defined[n.href]){
          n.media = 'print';
          n.onload = function(){ this.media = 'all'; };
          defined[n.href] = true;
        }
      });
    });
  });
  obs.observe(document.head, { childList: true });
  setTimeout(function(){ obs.disconnect(); }, 5000);
})();
</script>

