<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}" data-form-required-error="{{ 'forms.validation.required' | t }}" data-form-email-error="{{ 'forms.validation.email' | t }}" data-form-server-error="{{ 'newsletter.error_server' | t }}" data-newsletter-success="{{ 'newsletter.success' | t }}" data-newsletter-loading="{{ 'newsletter.loading' | t }}">
<head>
<!-- DNS Prefetch - lightweight hints for deferred third-party scripts -->
<!-- NOTE: cdn.shopify.com preconnect removed — Shopify sends it via HTTP headers automatically -->
<link rel="dns-prefetch" href="https://www.googletagmanager.com">
<link rel="dns-prefetch" href="https://connect.facebook.net">
<!-- Phase 3: WhatsApp API domain hint for floating CTA -->
<link rel="dns-prefetch" href="https://wa.me">
<link rel="dns-prefetch" href="https://api.whatsapp.com">

<!-- Preload critical JavaScript -->
{%- if request.design_mode -%}
<link rel="modulepreload" href="{{ 'theme-editor.js' | asset_url }}">
{%- endif -%}

<!-- Note: Image preloading should be done in sections, not in layout -->
{%- comment -%}
<!-- Preload de la primera imagen visible (hero) -->
{% if section.settings.image %}
  <link rel="preload" as="image" loading="eager"
    fetchpriority="high" href="{{ section.settings.image | image_url: width: 1920, quality: 85, format: 'webp' }}" imagesrcset="{{ section.settings.image | image_url: width: 750, quality: 85, format: 'webp' }} 750w, {{ section.settings.image | image_url: width: 1920, quality: 85, format: 'webp' }} 1920w" imagesizes="100vw">
{% endif %}

<!-- Preload del logo -->
<link rel="preload" as="image" href="{{ section.settings.logo | image_url: width: 200, quality: 85, format: 'webp' }}">
{%- endcomment -%}
    <!-- Meta Tags Básicos -->
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#1E3A5F">
    <link rel="canonical" href="{{ canonical_url }}">

    <!-- Hreflang tags for multilingual SEO -->
    {%- assign hreflang_path = canonical_url | remove: request.origin | remove_first: request.locale.root_url -%}
    {%- for language in localization.available_languages -%}
      <link rel="alternate" hreflang="{{ language.iso_code }}" href="{{ request.origin }}{{ language.root_url }}{{ hreflang_path }}">
    {%- endfor -%}
    <link rel="alternate" hreflang="x-default" href="{{ canonical_url }}">

    <!-- SEO Meta Description - Uses page-specific description or falls back to default -->
    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% elsif template.name == 'index' %}
      <meta name="description" content="TechAura ✓ Tienda online #1 de tecnología en Colombia. Audífonos, smartwatches, memorias USB personalizadas y accesorios tech con envío GRATIS y pago contra entrega. Garantía 30 días.">
    {% elsif template.name == 'collection' %}
      <meta name="description" content="{{ collection.title }} en TechAura. {{ collection.products_count }} productos tecnológicos con envío gratis a toda Colombia. Pago contra entrega disponible.">
    {% elsif template.name == 'product' %}
      <meta name="description" content="{{ product.title | escape }} - Desde {{ product.price | money }}. Envío GRATIS + Garantía 30 días + Pago contra entrega en toda Colombia. Compra seguro en TechAura.">
    {% elsif template contains 'article' %}
      <meta name="description" content="{{ article.excerpt_or_content | strip_html | truncate: 155 | escape }}">
    {% elsif template contains 'blog' %}
      <meta name="description" content="Blog TechAura - Guías, reseñas y consejos sobre tecnología, gadgets, audífonos, smartwatches y más. Tips para sacar el máximo provecho a tus dispositivos.">
    {% else %}
      <meta name="description" content="TechAura ✓ Tienda online de tecnología en Colombia. Audífonos, smartwatches, memorias USB y accesorios tech con envío GRATIS, pago contra entrega y garantía 30 días.">
    {% endif %}
    
    <!-- Localización Colombia -->
    <meta name="geo.region" content="CO">
    <meta name="geo.placename" content="Colombia">
    <meta name="geo.position" content="4.570868;-74.297333">
    <meta name="ICBM" content="4.570868, -74.297333">
    <meta name="country" content="Colombia">
    <meta name="language" content="es-CO">
    <meta name="distribution" content="Colombia">
    <meta property="og:locale" content="es_CO">
    
    <!-- SEO Esencial TechAura -->
    <meta name="author" content="TechAura">
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
    
    <!-- Open Graph and Twitter Card tags are rendered dynamically via snippets/meta-tags.liquid -->
    
    <!-- Structured Data: Organization (canonical source) -->
    {% render 'structured-data-base' %}

    <!-- Structured Data: WebSite with SearchAction (canonical source) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "TechAura",
      "url": "{{ shop.url }}",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "{{ shop.url }}/search?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
    </script>

    <!-- Product structured data is rendered via snippets/schema-product.liquid in sections/main-product.liquid -->

    <!-- Favicon -->
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32, quality: 85, format: 'webp' }}">
    {%- endif -%}

    {%- comment -%}
      Performance: Preconnect hints consolidated at top of <head> (lines 4-9).
      Avoid adding more than 4 preconnect hints total — see Lighthouse warning.
    {%- endcomment -%}

    <title>
      {%- if template.name == 'index' -%}
        TechAura | Tienda #1 de Tecnología en Colombia | Envío Gratis
      {%- elsif template.name == 'product' -%}
        {{ product.title }} | Desde {{ product.price | money }} | Envío GRATIS | TechAura
      {%- elsif template.name == 'collection' -%}
        {{ collection.title }} | Compra Online con Envío Gratis | TechAura
      {%- elsif template contains 'article' -%}
        {{ article.title }} | Blog TechAura
      {%- elsif template contains 'blog' -%}
        {{ blog.title | default: 'Blog' }} | Guías y Consejos Tech | TechAura
      {%- elsif template.name == '404' -%}
        Página no encontrada | TechAura
      {%- elsif template.name == 'search' -%}
        Buscar: {{ search.terms | escape }} | TechAura
      {%- else -%}
        {{ page_title }}
        {%- if current_tags %} &ndash; {{ current_tags | join: ', ' }}{% endif -%}
        {%- if current_page != 1 %} &ndash; Página {{ current_page }}{% endif -%}
        {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
      {%- endif -%}
    </title>
    
    <!-- Meta Tags de Shopify -->
    {% render 'meta-tags' %}

    {%- comment -%} SEO: Breadcrumbs Structured Data {%- endcomment -%}
    {% render 'schema-breadcrumbs' %}

    {%- comment -%} SEO: Collection Page Structured Data {%- endcomment -%}
    {%- if template.name == 'collection' and collection -%}
      {% render 'schema-collection', collection: collection %}
      {% render 'schema-itemlist', collection: collection %}
    {%- endif -%}

    {%- comment -%} SEO: Article/Blog Structured Data {%- endcomment -%}
    {%- if template contains 'article' and article -%}
      {% render 'schema-article', article: article %}
    {%- endif -%}
    <!-- Scripts Principales -->
    <script src="{{ 'constants.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'pubsub.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
    {%- if template.name == 'product' -%}
      <script src="{{ 'global-product.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
    
    {%- if settings.animations_reveal_on_scroll -%}
      <script src="{{ 'animations.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
    
    {%- comment -%} Scripts del rediseño {%- endcomment -%}
    {%- if template.name == 'product' -%}
      <script src="{{ 'cross-sell.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
    
    {%- comment -%} Non-critical scripts: loaded via requestIdleCallback to reduce main-thread work {%- endcomment -%}

    {{ content_for_header }}

    <!-- Estilos de Fuentes -->
    {%- liquid
      assign body_font_bold = settings.type_body_font | font_modify: 'weight', 'bold'
      assign body_font_italic = settings.type_body_font | font_modify: 'style', 'italic'
      assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'
    %}

    {%- comment -%} Phase 3: font-display: swap to eliminate FOIT {%- endcomment -%}
    <style>
      {{ settings.type_body_font | font_face: font_display: 'swap' }}
      {{ body_font_bold | font_face: font_display: 'swap' }}
      {{ body_font_italic | font_face: font_display: 'swap' }}
      {{ body_font_bold_italic | font_face: font_display: 'swap' }}
      {{ settings.type_header_font | font_face: font_display: 'swap' }}
    </style>

    {%- comment -%}
      FOUC guard removed — these rules are already inlined in the base-critical.css block below (line 239).
      Eliminating duplicate CSS parsing + style recalculation.
    {%- endcomment -%}
<!-- =============================================================================
     UNIFIED CSS - TECHAURAZ THEME STYLESHEET LOADING ORDER
     =============================================================================
     
     LOAD ORDER (Critical - do not change):
     
     GLOBAL (loaded on all pages):
     1. techauraz-tokens.css - CSS custom properties, design tokens + legacy --tech-* compat (MUST BE FIRST)
     2. base.css - Core Dawn theme styles + TechAura unified styles
     3. ui-ux-responsive-fixes.css - Responsive design and layout fixes
     4. home-modern-blocks.css - Newsletter + Footer styles (contains global footer styles)
     5. techauraz-custom-ui.css - WhatsApp, Announcement Bar, Cookie Banner
     6. techauraz-product-card.css - Product card conversion styles
     7. techauraz-utilities.css - Utility classes using design tokens
     8. header-announcement-slideshow-fixes.css - Header & Announcement Bar UI/UX fixes
     
     CONDITIONAL (loaded only on specific pages):
     A. testimonials.css - Reviews & carousel sections (HOME ONLY: template.name == 'index')
     B. slideshow-enhancements.css - Slider controls and CTAs (HOME ONLY: template.name == 'index')
     C. quick-view-modal.css - Product preview modal (HOME, COLLECTION, SEARCH pages)
     D. product-comparison.css - Side-by-side comparison (PDP & comparison pages)
     
     Z-INDEX HIERARCHY (defined in techauraz-tokens.css):
     - Base content: 0-99
     - Announcement/Header: 100-199
     - Drawers: 200-299
     - Dropdowns/Menus: 300-399
     - Modals/Cookie Banner: 400-499
     - WhatsApp FAB/Toast: 500+
     
     NOTE: Shopify's adopted-style-sheet is injected via content_for_header.
     This is normal Shopify behavior and should not interfere with our styles
     as long as the loading order is maintained.
     
     Last updated: 2026-03-13
     ============================================================================= -->

<!-- TechAura Design Tokens — render-blocking (supplies CSS custom properties used everywhere) -->
<link rel="stylesheet" href="{{ 'techauraz-tokens.css' | asset_url }}">

{%- comment -%}
  Critical base styles — INLINED to eliminate 490ms render-blocking request.
  Source: assets/base-critical.css (keep in sync if changed).
{%- endcomment -%}
