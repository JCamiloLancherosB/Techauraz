      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {%- comment -%} Cookie Banner REMOVED — Shopify built-in consent handles GDPR {%- endcomment -%}

    {%- comment -%} Quick View Modal - Rendered once globally {%- endcomment -%}
