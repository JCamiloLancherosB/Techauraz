{
  "sections": {
    "breadcrumbs": {
      "type": "breadcrumbs",
      "settings": {}
    },
    "banner": {
      "type": "main-collection-banner",
      "settings": {
        "show_collection_description": true,
        "show_collection_image": false,
        "color_scheme": "scheme-1"
      }
    },
    "benefits_conversion_collection": {
      "type": "benefits-conversion",
      "blocks": {
        "benefit_shipping": {
          "type": "benefit",
          "settings": {
            "icon": "shipping",
            "title": "Envío Gratis Colombia",
            "description": "Sin montos mínimos."
          }
        },
        "benefit_payment": {
          "type": "benefit",
          "settings": {
            "icon": "payment",
            "title": "Pago Contra Entrega",
            "description": "Paga al recibir."
          }
        },
        "benefit_guarantee": {
          "type": "benefit",
          "settings": {
            "icon": "guarantee",
            "title": "Garantía Premium",
            "description": "Compra 100% protegida."
          }
        },
        "benefit_delivery": {
          "type": "benefit",
          "settings": {
            "icon": "lightning",
            "title": "Despacho Rápido",
            "description": "Salida en 24 horas."
          }
        }
      },
      "block_order": [
        "benefit_shipping",
        "benefit_payment",
        "benefit_guarantee",
        "benefit_delivery"
      ],
      "settings": {
        "heading": "Compra 100% Segura"
      }
    },
    "product-grid": {
      "type": "main-collection-product-grid",
      "settings": {
        "products_per_page": 16,
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "image_ratio": "square",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": true,
        "enable_quick_add": true,
        "enable_filtering": true,
        "filter_type": "horizontal",
        "enable_sorting": true,
        "columns_mobile": "2",
        "padding_top": 40,
        "padding_bottom": 40
      }
    },
    "recently-viewed": {
      "type": "recently-viewed",
      "settings": {
        "section_title": "Vistos Recientemente",
        "heading_size": "h2",
        "products_to_show": 8,
        "show_view_all_link": false,
        "empty_state_text": "Aún no has explorado productos",
        "auto_hide_when_empty": true,
        "color_scheme": "scheme-1",
        "padding_top": 40,
        "padding_bottom": 40
      }
    }
  },
  "order": [
    "breadcrumbs",
    "banner",
    "benefits_conversion_collection",
    "product-grid",
    "recently-viewed"
  ]
}