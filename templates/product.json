{
    "sections": {
        "main": {
            "type": "main-product",
            "blocks": {
                "vendor": {
                    "type": "text",
                    "disabled": true,
                    "settings": {
                        "text": "{{ product.vendor }}",
                        "text_style": "uppercase"
                    }
                },
                "title": {
                    "type": "title",
                    "settings": {}
                },
                "variant_picker": {
                    "type": "variant_picker",
                    "settings": {
                        "picker_type": "button",
                        "swatch_shape": "circle"
                    }
                },
                "description": {
                    "type": "description",
                    "settings": {}
                },
                "price": {
                    "type": "price",
                    "settings": {}
                },
                "pdp_conversion_badges": {
                    "type": "custom_liquid",
                    "settings": {
                        "custom_liquid": "{% render 'pdp-conversion-badges' %}"
                    }
                },
                "pdp_key_specs": {
                    "type": "custom_liquid",
                    "settings": {
                        "custom_liquid": "{% render 'pdp-key-specs' %}"
                    }
                },
                "quantity_selector": {
                    "type": "quantity_selector",
                    "settings": {}
                },
                "buy_buttons": {
                    "type": "buy_buttons",
                    "settings": {
                        "show_dynamic_checkout": true,
                        "show_gift_card_recipient": true
                    }
                },
                "pdp_delivery_estimate": {
                    "type": "custom_liquid",
                    "settings": {
                        "custom_liquid": "{% render 'pdp-delivery-estimate' %}"
                    }
                },
                "trust_line": {
                    "type": "trust_line",
                    "settings": {
                        "text_shipping": "Envío gratis",
                        "text_1": "Contraentrega en Colombia",
                        "text_2": "Garantía 30 días",
                        "text_return": "Devolución fácil"
                    }
                },
                "pdp_whatsapp_cta": {
                    "type": "custom_liquid",
                    "settings": {
                        "custom_liquid": "{% render 'pdp-whatsapp-cta', product: product %}"
                    }
                },
                "share": {
                    "type": "share",
                    "settings": {
                        "share_label": "Compartir"
                    }
                }
            },
            "block_order": [
                "title",
                "price",
                "trust_line",
                "variant_picker",
                "quantity_selector",
                "buy_buttons",
                "pdp_delivery_estimate",
                "pdp_conversion_badges",
                "pdp_key_specs",
                "description",
                "pdp_whatsapp_cta",
                "share",
                "vendor"
            ],
            "custom_css": [],
            "settings": {
                "gallery_layout": "thumbnail_slider",
                "media_size": "large",
                "constrain_to_viewport": "true",
                "media_fit": "contain",
                "media_position": "left",
                "image_zoom": "hover",
                "mobile_thumbnails": "show",
                "hide_variants": true,
                "enable_sticky_info": true,
                "color_scheme": "scheme-1",
                "padding_top": 72,
                "padding_bottom": 24
            }
        },
        "product_benefits": {
            "type": "product-benefits",
            "blocks": {
                "benefit_1": {
                    "type": "benefit",
                    "settings": {
                        "emoji": "fire",
                        "title": "Calidad Premium Garantizada",
                        "description": "Si no supera tus expectativas, te devolvemos el 100% de tu dinero sin preguntas"
                    }
                },
                "benefit_2": {
                    "type": "benefit",
                    "settings": {
                        "emoji": "shipping",
                        "title": "Envío Gratis Express",
                        "description": "Recíbelo en 2-5 días hábiles sin costo adicional, directo a tu puerta"
                    }
                },
                "benefit_3": {
                    "type": "benefit",
                    "settings": {
                        "emoji": "sparkles",
                        "title": "Garantía de Satisfacción 30 Días",
                        "description": "Pruébalo sin riesgo. No te convence? Devolución gratis y reembolso completo"
                    }
                }
            },
            "block_order": [
                "benefit_1",
                "benefit_2",
                "benefit_3"
            ],
            "settings": {
                "heading": "Compra con Total Confianza y Seguridad",
                "padding_top": 40,
                "padding_bottom": 40
            }
        },
        "product_features": {
            "type": "product-features",
            "blocks": {
                "feature_1": {
                    "type": "feature",
                    "settings": {
                        "icon": "lightning",
                        "label": "Procesador",
                        "value": "Último modelo disponible"
                    }
                },
                "feature_2": {
                    "type": "feature",
                    "settings": {
                        "icon": "usb",
                        "label": "Almacenamiento",
                        "value": "Alta capacidad"
                    }
                }
            },
            "block_order": [
                "feature_1",
                "feature_2"
            ],
            "settings": {
                "heading": "Especificaciones Técnicas",
                "padding_top": 36,
                "padding_bottom": 36
            }
        },
        "product_includes": {
            "type": "product-includes",
            "blocks": {
                "item_1": {
                    "type": "item",
                    "settings": {
                        "item": "1x Producto principal"
                    }
                },
                "item_2": {
                    "type": "item",
                    "settings": {
                        "item": "1x Cable USB"
                    }
                },
                "item_3": {
                    "type": "item",
                    "settings": {
                        "item": "1x Manual de usuario en español"
                    }
                },
                "item_4": {
                    "type": "item",
                    "settings": {
                        "item": "Garantía de 30 días"
                    }
                }
            },
            "block_order": [
                "item_1",
                "item_2",
                "item_3",
                "item_4"
            ],
            "settings": {
                "heading": "¿Qué incluye?",
                "padding_top": 36,
                "padding_bottom": 36
            }
        },
        "product_usage_warranty": {
            "type": "product-usage-warranty",
            "blocks": {
                "step_1": {
                    "type": "usage_step",
                    "settings": {
                        "title": "Conecta el dispositivo",
                        "description": "Conecta el cable USB al puerto correspondiente de tu computadora o adaptador de corriente"
                    }
                },
                "step_2": {
                    "type": "usage_step",
                    "settings": {
                        "title": "Enciende el producto",
                        "description": "Presiona el botón de encendido durante 3 segundos hasta que veas la luz indicadora"
                    }
                },
                "step_3": {
                    "type": "usage_step",
                    "settings": {
                        "title": "Configura según tus necesidades",
                        "description": "Sigue las instrucciones en pantalla o en el manual de usuario para personalizar el producto"
                    }
                }
            },
            "block_order": [
                "step_1",
                "step_2",
                "step_3"
            ],
            "settings": {
                "show_usage_section": true,
                "usage_heading": "Cómo se Usa",
                "show_warranty_section": true,
                "warranty_heading": "Garantía y Soporte",
                "warranty_period_label": "Garantía de 30 días",
                "warranty_description": "Todos nuestros productos incluyen garantía de 30 días contra defectos de fabricación. Si algo falla, te lo reemplazamos sin costo.",
                "whatsapp_label": "Soporte por WhatsApp",
                "whatsapp_description": "¿Dudas o necesitas ayuda? Escríbenos por WhatsApp y te atendemos de inmediato.",
                "whatsapp_phone": "+573008602789",
                "whatsapp_message": "Hola! Necesito ayuda con un producto",
                "whatsapp_button_text": "Contactar por WhatsApp",
                "padding_top": 40,
                "padding_bottom": 40
            }
        },
        "shipping-returns": {
            "type": "shipping-returns",
            "settings": {
                "heading": "Envío y Pago",
                "show_timeline": true,
                "padding_top": 40,
                "padding_bottom": 40
            }
        },
        "product_faq": {
            "type": "product-faq",
            "blocks": {
                "faq_1": {
                    "type": "faq_item",
                    "settings": {
                        "question": "¿Cuánto tarda en llegar mi pedido?",
                        "answer": "<p>Tu pedido llegará en <strong>2 a 5 días hábiles</strong> a cualquier parte de Colombia. El envío es <strong>completamente GRATIS</strong> y recibirás un número de seguimiento para rastrear tu paquete en tiempo real.</p>"
                    }
                },
                "faq_2": {
                    "type": "faq_item",
                    "settings": {
                        "question": "¿Puedo pagar cuando reciba el producto?",
                        "answer": "<p>¡Por supuesto! Ofrecemos <strong>pago contra entrega</strong> en toda Colombia sin ningún costo adicional. Pagas en efectivo o con tarjeta directamente al mensajero cuando recibas tu producto. También aceptamos pagos en línea con tarjetas de crédito, débito, PSE y más.</p>"
                    }
                },
                "faq_3": {
                    "type": "faq_item",
                    "settings": {
                        "question": "¿Qué garantía tiene el producto?",
                        "answer": "<p>Todos nuestros productos incluyen <strong>garantía de 30 días</strong> por defectos de fabricación. Además, tienes <strong>30 días para devolución</strong> si no estás completamente satisfecho. Te devolvemos el 100% de tu dinero, sin complicaciones ni preguntas.</p>"
                    }
                },
                "faq_4": {
                    "type": "faq_item",
                    "settings": {
                        "question": "¿Es seguro comprar aquí?",
                        "answer": "<p><strong>¡Totalmente seguro!</strong> Procesamos todos los pagos a través de plataformas certificadas y encriptadas. Nunca almacenamos información sensible de tus tarjetas. Además, miles de clientes satisfechos respaldan nuestra tienda con excelentes reseñas.</p>"
                    }
                }
            },
            "block_order": [
                "faq_1",
                "faq_2",
                "faq_3",
                "faq_4"
            ],
            "settings": {
                "heading": "Preguntas Frecuentes",
                "padding_top": 40,
                "padding_bottom": 40
            }
        },
        "product_testimonials": {
            "type": "product-testimonials",
            "settings": {
                "heading": "Lo que Dicen Nuestros Clientes",
                "padding_top": 40,
                "padding_bottom": 40
            }
        },
        "shipping_timeline": {
            "type": "shipping-timeline",
            "settings": {
                "heading": "Proceso de Envío",
                "padding_top": 36,
                "padding_bottom": 36
            }
        },
        "sticky_mobile_cta": {
            "type": "sticky-mobile-cta",
            "settings": {
                "enable_sticky_cta": true,
                "show_benefits": true,
                "benefit_1_text": "Envío Gratis",
                "benefit_2_text": "Pago Contraentrega",
                "buy_button_text": "Agregar",
                "whatsapp_phone": "+573008602789",
                "whatsapp_button_text": "WhatsApp"
            }
        },
        "purchase_notification": {
            "type": "purchase-notification",
            "settings": {
                "enable_notifications": false,
                "interval": 15
            }
        },
        "related-products": {
            "type": "related-products",
            "custom_css": [],
            "settings": {
                "heading": "Productos que también te Encantarán",
                "heading_size": "h2",
                "products_to_show": 8,
                "columns_desktop": 4,
                "color_scheme": "scheme-1",
                "image_ratio": "adapt",
                "image_shape": "default",
                "show_secondary_image": true,
                "show_vendor": false,
                "show_rating": true,
                "columns_mobile": "2",
                "padding_top": 40,
                "padding_bottom": 40
            }
        },
        "product_reviews_summary": {
            "type": "product-reviews-summary",
            "settings": {
                "show_section": true,
                "placeholder_text": "Calificación garantizada"
            }
        },
        "product_trust_strip": {
            "type": "product-trust-strip",
            "settings": {
                "show_section": true,
                "text_guarantee": "Garantía 30 días",
                "text_shipping": "Envío GRATIS",
                "text_cod": "Paga al recibir",
                "text_stock_available": "En stock — envío hoy",
                "text_stock_unavailable": "Agotado temporalmente"
            }
        },
        "countdown_timer_pdp": {
            "type": "countdown-timer",
            "settings": {
                "enable_section": true,
                "heading": "¡OFERTA POR TIEMPO LIMITADO!",
                "subheading": "Aprovecha este descuento antes de que termine",
                "days_to_add": 2,
                "hours_to_add": 12,
                "button_label": "",
                "padding_top": 24,
                "padding_bottom": 24
            }
        },
        "cross_sell_pdp": {
            "type": "cross-sell",
            "settings": {
                "title": "Completa tu Compra",
                "subtitle": "Estos productos combinan perfectamente con tu elección"
            }
        },
        "recently-viewed": {
            "type": "recently-viewed",
            "settings": {
                "section_title": "Vistos Recientemente",
                "heading_size": "h2",
                "products_to_show": 8,
                "show_view_all_link": false,
                "empty_state_text": "Aún no has explorado productos",
                "auto_hide_when_empty": true,
                "color_scheme": "scheme-1",
                "padding_top": 40,
                "padding_bottom": 40
            }
        }
    },
    "order": [
        "main",
        "product_trust_strip",
        "countdown_timer_pdp",
        "product_benefits",
        "product_includes",
        "product_features",
        "product_usage_warranty",
        "shipping_timeline",
        "shipping-returns",
        "product_faq",
        "product_testimonials",
        "product_reviews_summary",
        "cross_sell_pdp",
        "related-products",
        "recently-viewed",
        "sticky_mobile_cta",
        "purchase_notification"
    ]
}